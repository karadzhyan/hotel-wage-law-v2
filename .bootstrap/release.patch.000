diff --git a/.github/ISSUE_TEMPLATE/bug.yml b/.github/ISSUE_TEMPLATE/bug.yml
new file mode 100644
index 0000000..91fd0b3
--- /dev/null
+++ b/.github/ISSUE_TEMPLATE/bug.yml
@@ -0,0 +1,52 @@
+name: Product or implementation defect
+description: Report a reproducible defect in the prototype, build, data contract, or interaction.
+title: "[Bug]: "
+labels: ["bug"]
+body:
+  - type: markdown
+    attributes:
+      value: |
+        Do not include privileged material, personal data, credentials, or non-public customer information.
+  - type: textarea
+    id: summary
+    attributes:
+      label: Defect summary
+      description: What is wrong, and what should happen instead?
+    validations:
+      required: true
+  - type: textarea
+    id: reproduction
+    attributes:
+      label: Reproduction steps
+      placeholder: |
+        1. Open …
+        2. Select …
+        3. Observe …
+    validations:
+      required: true
+  - type: input
+    id: route
+    attributes:
+      label: Route or file
+      placeholder: /app/changes/ or src/pages/changes.js
+  - type: dropdown
+    id: severity
+    attributes:
+      label: Severity
+      options:
+        - Blocks review or release
+        - Material functional defect
+        - Minor functional defect
+        - Visual or editorial defect
+    validations:
+      required: true
+  - type: textarea
+    id: environment
+    attributes:
+      label: Environment
+      description: Browser, viewport, operating system, branch, and commit if relevant.
+  - type: textarea
+    id: evidence
+    attributes:
+      label: Supporting evidence
+      description: Add screenshots, logs, or failing test output after removing sensitive material.
