diff --git a/.gitattributes b/.gitattributes
new file mode 100644
index 0000000..c62104a
--- /dev/null
+++ b/.gitattributes
@@ -0,0 +1,8 @@
+* text=auto eol=lf
+
+# Generated static output remains reviewable but should not dominate language statistics.
+docs/** linguist-generated=true
+
+# Preserve executable scripts.
+scripts/*.py text eol=lf
+tests/*.py text eol=lf
