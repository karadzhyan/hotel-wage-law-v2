diff --git a/.github/pull_request_template.md b/.github/pull_request_template.md
new file mode 100644
index 0000000..bd1e816
--- /dev/null
+++ b/.github/pull_request_template.md
@@ -0,0 +1,26 @@
+## What changed
+
+Describe the user, product, legal-content, data, or infrastructure change.
+
+## Why it changed
+
+State the problem, governing requirement, or decision this change addresses.
+
+## Evidence and validation
+
+- [ ] `npm test` passes
+- [ ] `npm run qa` passes for interface changes
+- [ ] New or changed legal propositions identify their authority and review date
+- [ ] Deterministic logic is separated from counsel judgment
+- [ ] Prototype data remains clearly identified as illustrative
+- [ ] Keyboard, responsive, and reduced-motion behavior were checked
+- [ ] No secrets, privileged material, or personal data are included
+- [ ] Product contracts or ADRs were updated when architecture changed
+
+## Screenshots or recordings
+
+Include before/after evidence for material interface changes.
+
+## Revalidation impact
+
+Identify any source versions, rules, findings, controls, evidence records, or decision records that this change invalidates or requires to be reviewed.
diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
new file mode 100644
index 0000000..3698684
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,58 @@
+name: CI
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+concurrency:
+  group: ci-${{ github.workflow }}-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  verify:
+    name: Verify
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    steps:
+      - name: Check out repository
+        uses: actions/checkout@v4
+
+      - name: Set up Node
+        uses: actions/setup-node@v4
+        with:
+          node-version: 22
+          cache: npm
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: '3.12'
+
+      - name: Install browser test dependency
+        run: |
+          python -m pip install --upgrade pip
+          python -m pip install playwright
+          python -m playwright install --with-deps chromium
+
+      - name: Verify build and data contracts
+        run: npm test
+
+      - name: Verify project-path deployment build
+        run: npm run check:pages
+
+      - name: Run browser acceptance suite
+        run: npm run qa
+
+      - name: Upload verified static build
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: verified-static-build-${{ github.sha }}
+          path: docs
+          if-no-files-found: error
+          retention-days: 14
diff --git a/.github/workflows/pages.yml b/.github/workflows/pages.yml
new file mode 100644
index 0000000..ba48397
--- /dev/null
+++ b/.github/workflows/pages.yml
@@ -0,0 +1,57 @@
+name: Deploy GitHub Pages prototype
+
+on:
+  push:
+    branches: [main]
+  workflow_dispatch:
+
+permissions:
+  contents: read
+  pages: write
+  id-token: write
+
+concurrency:
+  group: pages
+  cancel-in-progress: true
+
+jobs:
+  build:
+    name: Build review prototype
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    steps:
+      - name: Check out repository
+        uses: actions/checkout@v4
+
+      - name: Set up Node
+        uses: actions/setup-node@v4
+        with:
+          node-version: 22
+          cache: npm
+
+      - name: Validate source and contracts
+        run: npm test
+
+      - name: Build and verify project-path deployment
+        run: npm run check:pages
+
+      - name: Configure Pages
+        uses: actions/configure-pages@v5
+
+      - name: Upload Pages artifact
+        uses: actions/upload-pages-artifact@v3
+        with:
+          path: docs
+
+  deploy:
+    name: Deploy review prototype
+    needs: build
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    environment:
+      name: github-pages
+      url: ${{ steps.deployment.outputs.page_url }}
+    steps:
+      - name: Deploy to GitHub Pages
+        id: deployment
+        uses: actions/deploy-pages@v4
