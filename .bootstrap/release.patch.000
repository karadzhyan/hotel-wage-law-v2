diff --git a/.github/ISSUE_TEMPLATE/legal-content.yml b/.github/ISSUE_TEMPLATE/legal-content.yml
new file mode 100644
index 0000000..425a60e
--- /dev/null
+++ b/.github/ISSUE_TEMPLATE/legal-content.yml
@@ -0,0 +1,63 @@
+name: Legal-content or source change
+description: Propose a new or revised source, rule, interpretation, effective date, or jurisdiction record.
+title: "[Authority]: "
+labels: ["documentation"]
+body:
+  - type: markdown
+    attributes:
+      value: |
+        This template is for source-governed legal-content changes. Do not submit privileged advice, customer facts, or personal data in a public repository.
+  - type: input
+    id: jurisdiction
+    attributes:
+      label: Jurisdiction
+      placeholder: California / Los Angeles / Federal
+    validations:
+      required: true
+  - type: input
+    id: source
+    attributes:
+      label: Primary-source URL or citation
+      description: Provide the authoritative source whenever available.
+    validations:
+      required: true
+  - type: input
+    id: published
+    attributes:
+      label: Publication date
+      placeholder: YYYY-MM-DD
+  - type: input
+    id: effective
+    attributes:
+      label: Effective date or interval
+      placeholder: YYYY-MM-DD or describe the interval
+  - type: textarea
+    id: proposition
+    attributes:
+      label: Proposed legal proposition
+      description: State the proposition precisely and distinguish rule text from analysis.
+    validations:
+      required: true
+  - type: textarea
+    id: impact
+    attributes:
+      label: Affected objects and outputs
+      description: Identify issue briefs, jurisdiction records, calculators, applicability logic, matters, controls, and decision records that may require revalidation.
+    validations:
+      required: true
+  - type: textarea
+    id: uncertainty
+    attributes:
+      label: Uncertainty or competing interpretation
+      description: Identify unresolved language, conflicting guidance, or facts necessary to apply the rule.
+  - type: checkboxes
+    id: review
+    attributes:
+      label: Review gates
+      options:
+        - label: Primary authority has been attached or linked.
+          required: true
+        - label: The change has not been represented as approved legal advice.
+          required: true
+        - label: Any volatile rate or deadline includes an effective date.
+          required: true
diff --git a/.github/ISSUE_TEMPLATE/product-engineering.yml b/.github/ISSUE_TEMPLATE/product-engineering.yml
new file mode 100644
index 0000000..65f4ae4
--- /dev/null
+++ b/.github/ISSUE_TEMPLATE/product-engineering.yml
@@ -0,0 +1,54 @@
+name: Product, architecture, or engineering work
+description: Propose a scoped implementation, architecture, migration, accessibility, security, or platform task.
+title: "[Workstream]: "
+labels: ["enhancement"]
+body:
+  - type: textarea
+    id: outcome
+    attributes:
+      label: Required outcome
+      description: Describe the measurable end state rather than only the proposed feature.
+    validations:
+      required: true
+  - type: textarea
+    id: problem
+    attributes:
+      label: Problem and users
+      description: Who is affected, at what point in the legal-response lifecycle, and why the current state is insufficient?
+    validations:
+      required: true
+  - type: textarea
+    id: scope
+    attributes:
+      label: In scope
+      description: List the routes, governed objects, services, or product contracts involved.
+    validations:
+      required: true
+  - type: textarea
+    id: exclusions
+    attributes:
+      label: Explicitly out of scope
+  - type: textarea
+    id: acceptance
+    attributes:
+      label: Acceptance criteria
+      description: Include functional, accessibility, security, data-lineage, and test requirements.
+    validations:
+      required: true
+  - type: textarea
+    id: dependencies
+    attributes:
+      label: Dependencies and decisions
+      description: Identify prerequisite schemas, source audits, integrations, ADRs, or repository settings.
+  - type: dropdown
+    id: horizon
+    attributes:
+      label: Roadmap horizon
+      options:
+        - Foundation
+        - Public authority layer
+        - Enterprise pilot
+        - Production hardening
+        - Later / exploratory
+    validations:
+      required: true
