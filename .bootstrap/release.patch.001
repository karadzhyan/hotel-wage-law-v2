new file mode 100644
index 0000000..debc44b
--- /dev/null
+++ b/SECURITY.md
@@ -0,0 +1,39 @@
+# Security and privacy policy
+
+## Prototype status
+
+This repository contains a production-fidelity prototype and product specification. It is not an approved production system and must not be used to store or process customer data, employee data, privileged material, credentials, secrets, or production legal work product.
+
+## Reporting a vulnerability
+
+Do **not** open a public issue for a suspected vulnerability, exposed credential, privacy incident, or privileged-data concern.
+
+Use GitHub's private vulnerability-reporting channel when it is enabled for this repository. Until then, contact the repository owner privately through the contact method associated with the GitHub account. Include:
+
+- affected commit and path
+- reproduction steps
+- likely impact
+- any mitigation already taken
+
+Do not include live credentials or unnecessary personal data in the report.
+
+## Supported versions
+
+Only the current `main` branch is supported during the prototype phase.
+
+## Security gates before production
+
+A production release requires, at minimum:
+
+- tenant isolation and object-level authorization
+- privileged-matter and need-to-know access controls
+- encrypted evidence and document storage
+- secrets management and key rotation
+- immutable audit events and legal-hold support
+- dependency, SAST, DAST, and infrastructure scanning
+- incident response and breach-notification procedures
+- privacy review, retention schedules, and deletion workflows
+- backup, disaster recovery, observability, and resilience testing
+- manual accessibility and security review of every material workflow
+
+The normative production requirements are documented in [`product/SECURITY-PRIVACY.md`](product/SECURITY-PRIVACY.md).
diff --git a/build.js b/build.js
new file mode 100644
index 0000000..fece7e9
--- /dev/null
+++ b/build.js
@@ -0,0 +1,134 @@
+'use strict';
+
+const fs = require('node:fs');
+const path = require('node:path');
+
+const renderHome = require('./src/pages/home');
+const renderOverview = require('./src/pages/overview');
+const renderChanges = require('./src/pages/changes');
+const renderMatter = require('./src/pages/matter');
+const renderControls = require('./src/pages/controls');
+const renderResearch = require('./src/pages/research');
+const renderBrief = require('./src/pages/brief');
+const renderProperty = require('./src/pages/property');
+const renderMethodology = require('./src/pages/methodology');
+const renderIntelligence = require('./src/pages/intelligence');
+const renderJurisdictions = require('./src/pages/jurisdictions');
+const renderTools = require('./src/pages/tools');
+const platformData = require('./src/data/platform-data');
+
+const ROOT = __dirname;
+const OUT = path.join(ROOT, 'docs');
+const BASE_PATH = normalizeBase(process.env.BASE_PATH || '');
+
+const routes = [
+  { route: '/', render: renderHome },
+  { route: '/intelligence/', render: renderIntelligence },
+  { route: '/jurisdictions/', render: renderJurisdictions },
+  { route: '/tools/', render: renderTools },
+  { route: '/methodology/', render: renderMethodology },
+  { route: '/app/', render: renderOverview },
+  { route: '/app/changes/', render: renderChanges },
+  { route: '/app/matters/la-hotel-wage-2026/', render: renderMatter },
+  { route: '/app/controls/', render: renderControls },
+  { route: '/app/research/', render: renderResearch },
+  { route: '/app/briefs/la-hotel-wage-2026/', render: renderBrief },
+  { route: '/app/properties/dtla-01/', render: renderProperty }
+];
+
+function normalizeBase(value) {
+  if (!value || value === '/') return '';
+  return `/${value.replace(/^\/+|\/+$/g, '')}`;
+}
+
+function cleanOutput() {
+  fs.rmSync(OUT, { recursive: true, force: true });
+  fs.mkdirSync(OUT, { recursive: true });
+}
+
+function copyDirectory(source, target) {
+  fs.mkdirSync(target, { recursive: true });
+  for (const entry of fs.readdirSync(source, { withFileTypes: true })) {
+    const src = path.join(source, entry.name);
+    const dest = path.join(target, entry.name);
+    if (entry.isDirectory()) copyDirectory(src, dest);
+    else fs.copyFileSync(src, dest);
+  }
+}
+
+function outputPath(route) {
+  if (route === '/') return path.join(OUT, 'index.html');
+  return path.join(OUT, route.replace(/^\//, ''), 'index.html');
+}
+
+function applyBase(html) {
+  if (!BASE_PATH) return html;
+  return html
+    .replace(/(href|src)="\/(?!\/)/g, `$1="${BASE_PATH}/`)
+    .replace(/content="\/assets\//g, `content="${BASE_PATH}/assets/`);
+}
+
+function writePage(route, render) {
+  const destination = outputPath(route);
+  fs.mkdirSync(path.dirname(destination), { recursive: true });
+  const html = applyBase(render());
+  fs.writeFileSync(destination, html, 'utf8');
+}
+
+function renderNotFound() {
+  const base = BASE_PATH || '';
+  return `<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Page not found · Hotel Wage Law</title><link rel="stylesheet" href="${base}/assets/css/tokens.css"><link rel="stylesheet" href="${base}/assets/css/base.css"><style>body{display:grid;min-height:100vh;place-items:center;padding:24px;background:#07182f;color:#fff}.not-found{max-width:680px}.not-found small{color:#8fb4e8;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.not-found h1{margin:15px 0;color:#fff;font-family:var(--font-serif);font-size:clamp(52px,9vw,90px);font-weight:500}.not-found p{color:#b7c8d8;font-size:17px}.not-found a{display:inline-flex;margin-top:22px;padding:13px 18px;background:#d7981f;border-radius:8px;color:#07182f;font-weight:750}</style></head><body><main class="not-found"><small>Error 404</small><h1>This record does not exist.</h1><p>The requested route is not part of this prototype build. Return to the public platform or enterprise workspace.</p><a href="${base}/">Return to Hotel Wage Law</a></main></body></html>`;
+}
+
+function writeMetadata() {
+  const publicRoutes = routes.map(item => `${BASE_PATH}${item.route}`);
+  const manifest = {
+    name: platformData.product.name,
+    version: require('./package.json').version,
+    builtAt: process.env.BUILD_TIMESTAMP || '2026-07-13T00:00:00.000Z',
+    basePath: BASE_PATH || '/',
+    routes: publicRoutes,
+    sourceFiles: countFiles(path.join(ROOT, 'src')),
+    architecture: 'Static, dependency-free, deterministic prototype build'
+  };
+  fs.mkdirSync(path.join(OUT, 'assets', 'data'), { recursive: true });
+  fs.writeFileSync(path.join(OUT, 'assets', 'data', 'platform-data.json'), JSON.stringify(platformData, null, 2));
+  fs.writeFileSync(path.join(OUT, 'build-manifest.json'), JSON.stringify(manifest, null, 2));
+
+  const appPrefix = `${BASE_PATH}/app/`.replace(/\/\//g, '/');
+  fs.writeFileSync(path.join(OUT, 'robots.txt'), `User-agent: *\nDisallow: ${appPrefix}\n`);
+  fs.writeFileSync(path.join(OUT, '404.html'), renderNotFound());
+  fs.writeFileSync(path.join(OUT, '.nojekyll'), '');
+
+  const webManifestPath = path.join(OUT, 'assets', 'manifest.webmanifest');
+  if (fs.existsSync(webManifestPath)) {
+    const webManifest = JSON.parse(fs.readFileSync(webManifestPath, 'utf8'));
+    webManifest.start_url = `${BASE_PATH}/app/`.replace(/\/\//g, '/');
+    webManifest.scope = `${BASE_PATH}/`.replace(/\/\//g, '/');
+    fs.writeFileSync(webManifestPath, `${JSON.stringify(webManifest, null, 2)}\n`);
+  }
+}
+
+function countFiles(directory) {
+  let total = 0;
+  for (const entry of fs.readdirSync(directory, { withFileTypes: true })) {
+    total += entry.isDirectory() ? countFiles(path.join(directory, entry.name)) : 1;
+  }
+  return total;
+}
+
+function validateBuild() {
+  const missing = [];
+  for (const item of routes) {
+    const file = outputPath(item.route);
+    if (!fs.existsSync(file) || fs.statSync(file).size < 1000) missing.push(item.route);
+  }
+  if (missing.length) throw new Error(`Build validation failed. Missing or undersized routes: ${missing.join(', ')}`);
+}
+
+cleanOutput();
+copyDirectory(path.join(ROOT, 'src', 'assets'), path.join(OUT, 'assets'));
+for (const item of routes) writePage(item.route, item.render);
+writeMetadata();
+validateBuild();
+console.log(`Built ${routes.length} routes to ${path.relative(ROOT, OUT)}${BASE_PATH ? ` with base ${BASE_PATH}` : ''}.`);
