+  .hero-system__footer { grid-template-columns: repeat(3, 1fr); }
+  .hero-system__footer a { grid-column: 1 / -1; justify-self: stretch; justify-content: center; margin-top: 12px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,.13); }
+  .control-plane-section { grid-template-columns: 1fr; gap: 55px; }
+  .control-plane-copy { max-width: 780px; padding: 0; }
+  .control-plane-window { transform: none; }
+  .audience-grid { grid-template-columns: repeat(2, 1fr); }
+  .audience-grid article:nth-child(2) { border-right: 0; }
+  .audience-grid article:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
+  .evidence-standard-section { grid-template-columns: 1fr; gap: 45px; }
+  .research-foundation__grid { grid-template-columns: 1fr; }
+  .research-stack { grid-template-columns: repeat(3, 1fr); }
+  .research-stack > a { grid-template-columns: 45px 1fr; min-height: 165px; }
+  .research-stack > a > svg:last-child { display: none; }
+  .method-hero { gap: 55px; }
+  .overview-command-grid, .overview-lower-grid { grid-template-columns: 1fr; }
+  .control-domain-grid { grid-template-columns: repeat(2, 1fr); }
+  .scenario-grid { grid-template-columns: .85fr 1.15fr; }
+  .control-assurance-hero { grid-template-columns: 170px 1fr; }
+  .control-assurance-hero__facts { grid-column: 1 / -1; grid-template-columns: repeat(3, 1fr); margin-top: 18px; }
+  .property-rule-map { min-height: 620px; }
