+  .section-lead h2, .research-foundation__head h2, .evidence-standard__copy h2, .closing-manifesto h2 { font-size: 38px; }
+  .home-thesis, .audience-section, .research-foundation, .method-principles, .method-governance { padding: 76px 0; }
+  .consequence-chain { grid-template-columns: 1fr; }
