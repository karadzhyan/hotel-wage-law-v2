+  .evidence-layers li { grid-template-columns: 34px 1fr; }
+  .evidence-layers li > b { grid-column: 2; justify-self: start; }
+  .research-feature { min-height: 400px; padding: 28px; }
+  .research-feature h3 { margin-top: 48px; font-size: 34px; }
+  .research-feature footer { display: grid; gap: 10px; margin-top: 50px; }
+  .closing-manifesto { padding-top: 70px; padding-bottom: 70px; }
+  .method-hero { padding: 125px 18px 65px; }
+  .method-hero__copy h1 { font-size: 47px; }
+  .principle-grid { grid-template-columns: 1fr; }
+  .principle-grid article { min-height: 220px; border-right: 0 !important; }
+  .architecture-layers li { grid-template-columns: 45px 1fr; }
+  .architecture-layers li > b { grid-column: 2; justify-self: start; }
+  .governance-table { overflow-x: auto; }
+  .governance-row { grid-template-columns: 110px 250px 200px; min-width: 590px; }
+  .public-footer__main { grid-template-columns: 1fr 1fr; gap: 35px; }
+  .public-footer__main > div:first-child, .public-footer__cta { grid-column: 1 / -1; }
+  .public-footer__legal { display: grid; gap: 6px; }
+  .public-footer__legal span:last-child { margin-left: 0; }
+  .executive-brief { grid-template-columns: 1fr; }
+  .executive-brief__copy { padding: 25px; }
+  .executive-brief__copy h2 { font-size: 29px; }
+  .executive-brief__metrics { margin-top: 0; }
+  .overview-command-grid, .overview-lower-grid { grid-template-columns: 1fr; }
+  .signal-list { grid-template-columns: repeat(2, 1fr); }
+  .signal-item:nth-child(2) { border-right: 0; }
+  .signal-item:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
+  .signal-impact-grid, .change-facts, .property-command__facts { grid-template-columns: repeat(2, 1fr); }
+  .signal-impact-grid > div:nth-child(2), .change-facts > div:nth-child(2), .property-command__facts > div:nth-child(2) { border-right: 0; }
+  .signal-impact-grid > div:nth-child(-n+2), .change-facts > div:nth-child(-n+2), .property-command__facts > div:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
+  .topology-node { min-width: 125px; padding: 8px; }
+  .topology-node--la, .topology-node--ne { left: 10px; }
+  .topology-node--pnw, .topology-node--central { right: 10px; }
+  .change-workspace { display: block; min-height: 0; }
+  .change-inbox { max-height: 480px; overflow-y: auto; border-right: 0; border-bottom: 1px solid var(--line); }
+  .change-detail { padding: 18px; }
+  .change-detail__header, .change-verdict { grid-template-columns: 1fr; display: grid; }
+  .change-verdict__status { text-align: left; }
+  .decision-conversion { display: grid; }
+  .matter-context__identity { display: grid; }
+  .matter-context__meta { flex-wrap: wrap; }
+  .matter-lifecycle { grid-template-columns: repeat(2, 1fr); gap: 10px; }
+  .matter-decision { grid-template-columns: 1fr; }
+  .matter-decision__meta { grid-template-columns: 1fr 1fr; }
+  .matter-tabs { overflow-x: auto; }
+  .matter-tabs button { min-width: 120px; }
+  .scenario-grid { grid-template-columns: 1fr; }
+  .scenario-inputs { border-right: 0; border-bottom: 1px solid var(--line); }
+  .rule-stack, .control-plan-grid, .evidence-register-grid { grid-template-columns: 1fr; }
+  .rule-stack article, .control-plan-grid article, .evidence-register-grid article { border-right: 0; border-bottom: 1px solid var(--line); }
+  .record-preview { grid-template-columns: 1fr; }
+  .control-assurance-hero { grid-template-columns: 1fr; text-align: left; }
+  .control-assurance-hero__score { margin: 0 auto; }
+  .control-assurance-hero__facts { grid-template-columns: 1fr; }
+  .control-domain-grid { grid-template-columns: 1fr; }
+  .control-matrix .panel