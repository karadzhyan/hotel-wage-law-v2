+  .rule-map-card--workload { bottom: 35px; left: 25px; }
+  .rule-map-card--scheduling { right: 25px; bottom: 35px; }
+}
+
+@media (max-width: 980px) {
+  .public-header__inner { width: calc(100% - 36px); }
+  .public-nav, .public-header__actions { display: none; }
+  .mobile-menu-button { display: grid; }
+  .home-hero { min-height: auto; }
+  .home-hero__inner { grid-template-columns: 1fr; padding-top: 95px; }
+  .home-hero__copy { max-width: 760px; }
+  .hero-system { max-width: 760px; }
+  .hero-proof { grid-template-columns: repeat(2, 1fr); }
+  .proof-metric { border-bottom: 1px solid rgba(255,255,255,.12); }
+  .proof-metric:nth-child(2) { border-right: 0; }
+  .proof-metric:nth-last-child(-n+2) { border-bottom: 0; }
+  .proof-metric:nth-child(3) { padding-left: 0; }
+  .section-lead--split, .research-foundation__head, .closing-manifesto, .method-limitations { grid-template-columns: 1fr; gap: 30px; }
+  .consequence-chain { grid-template-columns: repeat(2, 1fr); }
+  .consequence-chain article:nth-child(2) { border-right: 0; }
+  .consequence-chain article:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
+  .research-stack { grid-template-columns: 1fr; }
+  .research-stack > a { min-height: 120px; }
+  .public-footer__main { grid-template-columns: 1.2fr .8fr .8fr; }
+  .public-footer__cta { grid-column: 1 / -1; padding: 28px 0 0; border-top: 1px solid rgba(255,255,255,.12); border-left: 0; }
+  .method-hero { grid-template-columns: 1fr; padding-top: 145px; }
+  .principle-grid { grid-template-columns: repeat(2, 1fr); }
+  .principle-grid article:nth-child(3n) { border-right: 1px solid var(--line); }
+  .principle-grid article:nth-child(2n) { border-right: 0; }
+  .governance-row { grid-template-columns: .6fr 1.4fr 1fr; }
+  .governance-row > :last-child { display: none; }
+  .page-layout--with-rail { grid-template-columns: 1fr; }
+  .page-rail { position: static; display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
+  .page-rail .rail-card { margin: 0; }
+  .page-rail .rail-card:last-child:nth-child(odd) { grid-column: 1 / -1; }
+  .change-workspace { grid-template-columns: 290px minmax(0, 1fr); }
+  .impact-path { grid-template-columns: 1fr; gap: 8px; }
+  .impact-path > i { width: auto; height: 18px; transform: rotate(90deg); }
+  .matter-findings-grid, .property-grid { grid-template-columns: 1fr; }
+  .control-plan-grid { grid-template-columns: repeat(2, 1fr); }
+  .control-plan-grid article:nth-child(2) { border-right: 0; }
+  .control-plan-grid article:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
+  .assurance-cycle ol { grid-template-columns: repeat(3, 1fr); }
+  .assurance-cycle li:nth-child(3) { border-right: 0; }
+  .assurance-cycle li:nth-child(-n+3) { border-bottom: 1px solid var(--line); }
+  .research-workspace { grid-template-columns: 180px minmax(0, 1fr); }
+  .record-two-column { grid-template-columns: 1fr; }
+  .record-two-column .record-section:first-child { padding-right: 0; border-right: 0; border-bottom: 1px solid var(--line); }
+  .record-two-column .record-section:last-child { padding-left: 0; }
+  .property-rule-map { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; min-height: 0; padding: 20px; }
+  .rule-map-center { position: relative; grid-column: 1 / -1; top: auto; left: auto; width: 115px; height: 115px; margin: 0 auto 5px; transform: none; }
+  .rule-map-card { position: static; width: auto; }
+  .rule-map-lines { display: none; }
+}
+
+@media (max-width: 760px) {
+  :root { --topbar-height: 62px; }
+  body { font-size: 14px; }
+  .app-content { width: calc(100% - 24px); padding-top: 20px; }
+  .app-topbar { padding: 0 12px; gap: 9px; }
+  .breadcrumbs a, .breadcrumbs svg, .topbar-status, .global-ask span, .global-ask kbd { display: none; }
