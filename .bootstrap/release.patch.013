+  .home-hero__inner, .hero-proof, .home-thesis, .audience-section, .research-foundation, .method-principles, .method-governance, .public-footer__main, .public-footer__legal { width: calc(100% - 28px); }
+  .home-hero__inner { padding-top: 60px; }
