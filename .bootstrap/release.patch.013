 > svg { color: var(--blue-700); }
+.closing-manifesto { display: grid; grid-template-columns: 1fr .75fr; gap: 100px; align-items: center; margin-top: 20px; padding: 90px max(32px, calc((100vw - var(--public-max)) / 2)); color: var(--paper); background: linear-gradient(120deg, #07172a, #0b2b4d); }
+.closing-manifesto h2 { margin: 14px 0 0; color: var(--paper); font-family: var(--font-serif); font-size: 55px; font-weight: 500; }
+.closing-manifesto p { color: #c3d0dd; font-size: 16px; line-height: 1.65; }
+
+/* Public methodology */
+.method-hero { display: grid; grid-template-columns: .95fr 1.05fr; gap: 100px; align-items: center; min-height: 710px; padding: 150px max(32px, calc((100vw - var(--public-max)) / 2)) 80px; color: var(--paper); background: radial-gradient(circle at 75% 15%, #214f75, transparent 35%), linear-gradient(135deg, #061426, #0a2946); }
+.method-hero__copy h1 { margin: 0 0 25px; color: var(--paper); font-family: var(--font-serif); font-size: clamp(55px, 5vw, 78px); font-weight: 500; line-height: .98; }
+.method-hero__copy h1 em { color: #e5ad37; font-style: italic; }
+.method-hero__copy > p { max-width: 650px; color: #c5d2df; font-size: 17px; line-height: 1.7; }
+.method-proof-card { overflow: hidden; color: var(--ink-900); background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); }
+.method-proof-card header { display: grid; grid-template-columns: 40px 1fr auto; gap: 14px; align-items: center; padding: 22px; background: var(--canvas-warm); border-bottom: 1px solid var(--line); }
+.method-proof-card header > span { display: grid; place-items: center; width: 40px; height: 40px; color: var(--green-700); background: var(--green-100); border-radius: 11px; }
+.method-proof-card header small, .method-proof-card header strong { display: block; }
+.method-proof-card header small { color: var(--ink-500); font-size: 9px; }
+.method-proof-card header > b { padding: 6px 9px; color: var(--green-700); background: var(--green-50); border: 1px solid #c5e6d4; border-radius: var(--radius-pill); font-size: 9px; }
+.method-proof-card ol { margin: 0; padding: 0 22px; list-style: none; }
+.method-proof-card li { display: grid; grid-template-columns: 33px 1fr auto; gap: 13px; align-items: center; padding: 19px 0; border-bottom: 1px solid var(--line); }
+.method-proof-card li > span { color: var(--blue-700); font-family: var(--font-serif); font-size: 17px; }
+.method-proof-card li strong, .method-proof-card li small { display: block; }
+.method-proof-card li small { color: var(--ink-500); font-size: 9px; }
+.method-proof-card li > b { color: var(--green-700); font-size: 9px; }
+.method-proof-card footer { padding: 16px 22px; color: var(--ink-600); background: var(--ink-50); font-size: 10px; }
+.principle-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--ink-300); }
+.principle-grid article { min-height: 260px; padding: 30px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
+.principle-grid article:nth-child(3n) { border-right: 0; }
+.principle-grid article > span:first-child { display: grid; place-items: center; width: 42px; height: 42px; color: var(--blue-700); background: var(--blue-50); border-radius: 11px; }
+.principle-grid article > small { float: right; margin-top: -35px; color: var(--ink-300); font-family: var(--font-serif); font-size: 22px; }
+.principle-grid h3 { margin: 31px 0 10px; font-size: 21px; }
+.principle-grid p { color: var(--ink-600); font-size: 12px; line-height: 1.7; }
+.evidence-architecture { padding: 110px max(32px, calc((100vw - var(--public-max)) / 2)); color: var(--paper); background: var(--ink-950); }
+.evidence-architecture .section-lead h2 { color: var(--paper); }
+.evidence-architecture .section-lead p { color: #9fb0c1; }
+.architecture-layers { margin: 0; padding: 0; border-top: 1px solid rgba(255,255,255,.20); list-style: none; }
+.architecture-layers li { display: grid; grid-template-columns: 70px 1fr 145px; gap: 25px; align-items: center; padding: 24px 5px; border-bottom: 1px solid rgba(255,255,255,.12); }
+.architecture-layers li > span { color: #6ea4ed; font-family: var(--font-serif); font-size: 27px; }
+.architecture-layers small { color: #7f96ab; font-size: 8px; font-weight: 760; letter-spacing: .09em; text-transform: uppercase; }
+.architecture-layers h3 { margin: 4px 0; color: var(--paper); font-family: var(--font-serif); font-size: 25px; font-weight: 500; }
+.architecture-layers p { margin: 0; color: #a7b6c5; font-size: 11px; }
+.architecture-layers b { justify-self: end; color: #e5ad37; font-size: 9px; letter-spacing: .08em; text-transform: uppercase; }
+.governance-table { border-top: 1px solid var(--ink-300); }
+.governance-row { display: grid; grid-template-columns: .6fr 1.6fr 1.25fr .8fr; gap: 20px; padding: 17px 12px; border-bottom: 1px solid var(--line); font-size: 11px; }
+.governance-row--head { color: var(--ink-500); background: var(--ink-50); font-size: 8.5px; font-weight: 760; letter-spacing: .08em; text-transform: uppercase; }
+.governance-row strong { color: var(--ink-900); }
+.governance-row span { color: var(--ink-600); }
+.method-limitations { display: grid; grid-template-columns: .8fr 1.2fr; gap: 100px; padding: 95px max(32px, calc((100vw - var(--public-max)) / 2)); background: var(--gold-50); border-top: 1px solid #ecd8a7; }
+.method-limitations h2 { margin: 13px 0 0; font-family: var(--font-serif); font-size: 45px; font-weight: 500; }
+.method-limitations p { color: var(--ink-700); font-size: 14px; line-height: 1.7; }
+.method-limitations ul { margin: 25px 0 0; padding: 0; list-style: none; }
+.method-limitations li { display: flex; gap: 9px; padding: 7px 0; color: var(--ink-700); font-size: 11px; }
+.method-limitations svg { color: var(--green-700); }
+
+/* Footer */
+.public-footer { color: #c4d0dc; background: #040d19; }
+.public-footer__main { display: grid; grid-template-columns: 1.3fr .65fr .65fr 1.2fr; gap: 65px; width: min(calc(100% - 64px), var(--public-max)); margin: 0 auto; padding: 70px 0 55px; }
+.public-footer__main > div:first-child p { max-width: 280px; margin-top: 22px; color: #8195a8; font-size: 11px; }
+.public-footer__main h2 { margin: 0 0 17px; color: var(--paper); font-size: 11px; letter-spacing: .07em; text-transform: uppercase; }
+.public-footer__main > div:not(:first-child) > a:not(.button) { display: block; padding: 6px 0; color: #8fa3b6; font-size: 10px; }
+.public-footer__cta { padding-left: 35px; border-left: 1px solid rgba(255,255,255,.12); }
+.public-footer__cta h2 { margin: 12px 0 20px; font-family: var(--font-serif); font-size: 29px; font-weight: 500; letter-spacing: -.03em; text-transform: none; }
+.public-footer__legal { display: flex; gap: 30px; width: min(calc(100% - 64px), var(--public-max)); margin: 0 auto; padding: 18px 0 25px; color: #667b8e; border-top: 1px solid rgba(255,255,255,.10); font-size: 8px; }
+.public-footer__legal span:last-child { margin-left: auto; }
diff --git a/src/assets/css/responsive.css b/src/assets/css/responsive.css
new file mode 100644
index 0000000..051b1dc
--- /dev/null
+++ b/src/assets/css/responsive.css
