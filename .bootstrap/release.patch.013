+  .consequence-chain article small { left: 0; }
+  .control-plane-section, .evidence-standard-section, .closing-manifesto, .evidence-architecture, .method-limitations { padding-right: 18px; padding-left: 18px; }
+  .control-plane-copy h2 { font-size: 38px; }
