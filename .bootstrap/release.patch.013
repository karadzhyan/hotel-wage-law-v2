+@media (max-width: 1380px) {
+  :root { --sidebar-width: 248px; }
+  .app-content { width: min(calc(100% - 36px), 1560px); }
+  .page-layout--with-rail { grid-template-columns: minmax(0, 1fr) 275px; }
+  .public-header__inner, .home-hero__inner, .hero-proof, .home-thesis, .audience-section, .research-foundation, .method-principles, .method-governance, .public-footer__main, .public-footer__legal { width: min(calc(100% - 48px), var(--public-max)); }
+  .home-hero__inner { gap: 55px; }
+  .control-plane-section { grid-template-columns: .65fr 1.35fr; }
+  .control-plane-copy h2 { font-size: 44px; }
+  .change-workspace { grid-template-columns: 320px minmax(0, 1fr); }
+  .impact-path article { padding: 12px; }
+  .rule-map-card { width: 270px; }
+}
+
+@media (max-width: 1180px) {
+  .app-sidebar { transform: translateX(-102%); transition: transform var(--duration) var(--ease-out); box-shadow: var(--shadow-lg); }
+  .app-sidebar.is-open { transform: none; }
+  .sidebar-close, .sidebar-open { display: grid; }
+  .app-main { margin-left: 0; }
+  .app-content { width: min(calc(100% - 36px), 1500px); }
+  .page-layout--with-rail { grid-template-columns: minmax(0, 1fr) 280px; }
+  .public-nav { gap: 19px; }
+  .public-header__actions .quiet-action { display: none; }
+  .home-hero__inner { grid-template-columns: 1fr 1fr; gap: 42px; }
