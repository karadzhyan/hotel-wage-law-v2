+.decision-queue li footer { display: flex; justify-content: space-between; margin-top: 11px; color: var(--ink-500); font-size: 8px; }
+.decision-queue li footer a, .decision-queue li footer button { color: var(--blue-700); background: transparent; border: 0; font-weight: 720; }
+.queue-proof { display: flex; gap: 10px; margin: 15px; padding: 12px; background: var(--blue-50); border: 1px solid #d2e1fb; border-radius: var(--radius-sm); }
+.queue-proof > span { color: var(--blue-700); }
+.queue-proof strong { font-size: 10px; }
+.queue-proof p { margin: 2px 0 0; color: var(--ink-500); font-size: 8px; }
+.overview-lower-grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 18px; }
+.portfolio-reach, .control-posture { overflow: hidden; }
+.topology-chart { position: relative; min-height: 330px; background: radial-gradient(circle at center, var(--blue-50), transparent 31%), linear-gradient(var(--ink-50), var(--paper)); }
+.topology-center { position: absolute; z-index: 2; top: 50%; left: 50%; display: grid; place-items: center; width: 100px; height: 100px; transform: translate(-50%, -50%); color: var(--paper); background: linear-gradient(145deg, var(--ink-900), var(--blue-700)); border: 8px solid var(--paper); border-radius: 50%; box-shadow: var(--shadow-md); }
+.topology-center strong, .topology-center small { display: block; }
+.topology-center strong { margin-top: 3px; font-size: 22px; }
+.topology-center small { color: #c2d0df; font-size: 7px; }
+.topology-node { position: absolute; z-index: 2; display: flex; align-items: center; gap: 9px; min-width: 150px; padding: 10px 12px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); }
+.topology-node strong, .topology-node small { display: block; }
+.topology-node strong { font-size: 10px; }
+.topology-node small { color: var(--ink-500); font-size: 7px; }
+.topology-node b { margin-left: auto; padding: 3px 6px; color: var(--ink-600); background: var(--ink-50); border-radius: var(--radius-pill); font-size: 7px; }
+.topology-node--la { top: 35px; left: 25px; }
+.topology-node--pnw { top: 35px; right: 25px; }
+.topology-node--ne { bottom: 35px; left: 25px; }
+.topology-node--central { right: 25px; bottom: 35px; }
+.topology-node--la b { color: var(--red-700); background: var(--red-50); }
+.topology-node--pnw b, .topology-node--ne b { color: var(--gold-700); background: var(--gold-50); }
+.topolog