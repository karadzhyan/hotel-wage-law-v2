+.signal-detail { padding: 18px 22px 20px; }
+.signal-detail__header { display: flex; align-items: flex-start; justify-content: space-between; gap: 15px; }
+.signal-detail__header > div:first-child { display: flex; align-items: center; gap: 11px; }
+.signal-detail__header > div:first-child > span { display: grid; place-items: center; width: 36px; height: 36px; color: var(--blue-700); background: var(--blue-50); border-radius: 10px; }
+.signal-detail__header small, .signal-detail__header strong { display: block; }
