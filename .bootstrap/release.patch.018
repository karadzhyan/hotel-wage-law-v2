@@ -0,0 +1,122 @@
+'use strict';
+
+const { publicShell } = require('../components/public-shell');
+const { icon } = require('../components/icons');
+const { jurisdictionRecords } = require('../data/platform-data');
+
+function hero() {
+  return `<section class="jurisdictions-hero"><div><span class="hero-kicker"><i></i> Jurisdiction intelligence</span><h1>Know the rule.<br>Then resolve <em>the property.</em></h1><p>State and District of Columbia records establish the legal architecture. Hotel-specific local laws and governed property facts determine the answer that operations can actually use.</p><div class="hero-actions"><a class="button button--accent button--large" href="#explorer">Explore 51 jurisdictions ${icon('arrow-right')}</a><a class="button button--ghost-light button--large" href="#compare">Compare complexity</a></div></div><aside class="jurisdiction-metrics"><div><strong>51</strong><span>State + D.C.</span><small>Effective-dated records</small></div><div><strong>19</strong><span>Hotel-specific laws</span><small>Wage, benefit, workload, retention</small></div><div><strong>4</strong><span>Complexity tiers</span><small>Transparent triage—not legal outcomes</small></div><div><strong>100%</strong><span>Source lineage target</span><small>Passage-level primary authority</small></div><footer>${icon('info')} Public jurisdiction records are not property-specific legal determinations.</footer></aside></section>`;
+}
+
+function explorer() {
+  const cards = jurisdictionRecords.map(record => `<button class="jurisdiction-card jurisdiction-card--t${record.tier} ${record.code==='CA'?'is-selected':''}" data-jurisdiction-card data-jurisdiction-code="${record.code}" data-jurisdiction-name="${record.name}" data-jurisdiction-tier="${record.tier}" data-jurisdiction-rate="${record.rate}" data-jurisdiction-tip="${record.tip}" data-jurisdiction-overtime="${record.overtime}" data-jurisdiction-hotel="${record.hotel}"><span><strong>${record.code}</strong><small>${record.name}</small></span>${record.hotel.toLowerCase().includes('hotel')||record.hotel.toLowerCase().includes('hospitality')?icon('building'):''}<b>Tier ${record.tier}</b></button>`).join('');
+  return `<section class="jurisdiction-explorer" id="explorer"><header class="section-lead section-lead--split"><div><span class="eyebrow">Fifty-one records</span><h2>Explore the legal architecture before property facts change the answer.</h2></div><p>Complexity tiers summarize the number and interaction of state, local, industry, scheduling, tip, break, and remedies layers. Every tier remains inspectable.</p></header><div class="tier-ribbon"><button class="is-active" data-jurisdiction-tier="all"><span>${icon('grid')}</span><div><strong>All jurisdictions</strong><small>24 shown in prototype</small></div></button><button data-jurisdiction-tier="4"><i class="tier-4"></i><div><strong>Tier 4</strong><small>Dense interacting layers</small></div></button><button data-jurisdiction-tier="3"><i class="tier-3"></i><div><strong>Tier 3</strong><small>Material state/local overlays</small></div></button><button data-jurisdiction-tier="2"><i class="tier-2"></i><div><strong>Tier 2</strong><small>Meaningful state variance</small></div></button><button data-jurisdiction-tier="1"><i class="tier-1"></i><div><strong>Tier 1</strong><small>Federal-heavy baseline</small></div></button></div>
+    <div class="jurisdiction-workspace"><div><label class="inbox-search">${icon('search')}<input data-jurisdiction-search aria-label="Search jurisdictions" placeholder="Search state or code"></label><div class="jurisdiction-grid">${cards}</div></div><aside class="jurisdiction-inspector" data-jurisdiction-inspector><header><span class="jurisdiction-inspector__code" data-jurisdiction-inspector-code>CA</span><div><small>Selected jurisdiction</small><h2 data-jurisdiction-inspector-name>California</h2><p data-jurisdiction-inspector-tier>Tier 4 complexity</p></div><span class="status status--critical">Hotel overlays</span></header><div class="jurisdiction-inspector__facts"><div><small>State wage floor</small><strong data-jurisdiction-inspector-rate>$16.90+</strong><span>Local rates may control</span></div><div><small>Tip architecture</small><strong data-jurisdiction-inspector-tip>No tip credit</strong><span>Tips separate from wage</span></div><div><small>Overtime</small><strong data-jurisdiction-inspector-overtime>Daily + weekly</strong><span>Alternative schedules possible</span></div><div><small>Hotel layer</small><strong data-jurisdiction-inspector-hotel>Extensive local laws</strong><span>Property location controls</span></div></div><div class="jurisdiction-inspector__obligations"><small>Key hotel dimensions</small><ul><li>${icon('check-circle')} Local hotel wage and benefit ordinances</li><li>${icon('check-circle')} Housekeeper workload caps and premiums</li><li>${icon('check-circle')} Meal, rest, reporting, and split-shift rules</li><li>${icon('check-circle')} Wage statements, waiting time, and PAGA</li></ul></div><footer class="jurisdiction-inspector__actions"><button class="button button--primary" data-toast="The complete jurisdiction guide would open here.">Open full guide</button><button class="button button--secondary" data-toast="California added to the comparison workspace.">Compare</button><a class="button button--secondary" href="/app/properties/dtla-01/">Resolve a property</a></footer></aside></div>
+  </section>`;
+}
+
+function compare() {
+  return `<section class="jurisdiction-compare-demo" id="compare"><header class="section-lead section-lead--split"><div><span class="eyebrow">Side-by-side</span><h2>Compare rules without flattening their differences.</h2></div><p>The comparison makes exceptions, local-law dependencies, effective dates, and evidence quality visible—rather than reducing each state to one checkmark.</p></header><div class="compare-table"><div class="compare-table__row compare-table__row--head"><div>Dimension</div><div><strong>California</strong><small>Tier 4 · Jun 13 review</small></div><div><strong>New York</strong><small>Tier 4 · Jun 10 review</small></div><div><strong>Washington</strong><small>Tier 4 · Jun 8 review</small></div><div><strong>Texas</strong><small>Tier 1 · Jun 1 review</small></div></div><div class="compare-table__row"><div>Cash wage before tips</div><div>Full applicable minimum</div><div>Hospitality cash-wage tiers</div><div>Full applicable minimum</div><div>Federal tip-credit model</div></div><div class="compare-table__row"><div>Daily overtime</div><div>${icon('check-circle')} Yes</div><div>Generally no</div><div>Generally no</div><div>No</div></div><div class="compare-table__row"><div>Break architecture</div><div>Meal + rest premiums</div><div>Meal-period rules</div><div>Paid rest-break layer</div><div>Federal baseline</div></div><div class="compare-table__row"><div>Hotel-specific reach</div><div>Multiple city/county laws</div><div>Hospitality wage order</div><div>Seattle / SeaTac</div><div>No broad hotel layer</div></div><div class="compare-table__row"><div>Material remedies</div><div>Wage, penalties, PAGA</div><div>Wage, liquidated, frequency</div><div>Wage, double damages</div><div>FLSA + state remedies</div></div></div></section>`;
+}
+
+function bridge() {
+  return `<section class="jurisdiction-bridge"><div><span class="eyebrow eyebrow--light">From jurisdiction to applicability</span><h2>A state guide cannot tell you whether one hotel, worker, or pay practice is covered.</h2><p>The enterprise plane resolves the rule against address, locality, room count, ownership/operator relationships, workforce segments, systems, and effective-dated facts.</p></div><a class="button button--accent button--large" href="/app/properties/dtla-01/">Open a property passport ${icon('arrow-right')}</a></section>`;
+}
+
+module.exports = function renderJurisdictions() {
+  return publicShell({ activeKey: 'jurisdictions', title: 'Jurisdictions · Hotel Wage Law', description: 'Effective-dated state and local hospitality wage-and-hour intelligence with property-level applicability context.', content: `${hero()}${explorer()}${compare()}${bridge()}` });
+};
diff --git a/src/pages/matter.js b/src/pages/matter.js
new file mode 100644
index 0000000..8e3936e
--- /dev/null
+++ b/src/pages/matter.js
@@ -0,0 +1,332 @@
+'use strict';
+
+const { appShell } = require('../components/app-shell');
+const { icon } = require('../components/icons');
+const { properties } = require('../data/platform-data');
+
+function pageHeading() {
+  return `<header class="page-heading"><div><span class="eyebrow">Governed matter · MTR-2026-041</span><h1>Resolve the matter once. Reuse the answer everywhere.</h1><p>Scope, facts, law, analysis, scenarios, findings, owners, controls, evidence, and decision state remain versioned on one record.</p></div><div class="page-heading__actions"><button class="button button--secondary" data-toast="A matter activity export was prepared.">${icon('download')} Export record</button><a class="button button--primary" href="/app/briefs/la-hotel-wage-2026/">Open decision record ${icon('arrow-right')}</a></div></header>`;
+}
+
+function matterContext() {
+  return `<section class="panel matter-context">
+    <div class="matter-context__identity"><span class="matter-id">MTR<br>041</span><div><small>Material legal response</small><h2>Los Angeles hotel wage and health-benefit step</h2><p>Opened Jun 13, 2026 · Seven properties · Southern California cluster</p></div></div>
+    <div class="matter-context__meta"><div><small>Owner</small><strong>Employment Counsel</strong></div><div><small>Privilege</small><strong>Attorney work product</strong></div><div><small>Due</small><strong class="critical-text">Jun 16 · 5:00 PM</strong></div><button class="source-button" data-open-overlay="sources">${icon('source')} 6 governed sources</button></div>
+    <ol class="matter-lifecycle"><li class="is-complete"><span>${icon('search')}</span><div><small>Stage 01</small><strong>Assess</strong><p>Change and scope confirmed</p></div></li><li class="is-active"><span>${icon('decision')}</span><div><small>Stage 02</small><strong>Decide</strong><p>Executive approval due</p></div></li><li><span>${icon('settings')}</span><div><small>Stage 03</small><strong>Implement</strong><p>Payroll and benefits changes</p></div></li><li><span>${icon('shield')}</span><div><small>Stage 04</small><strong>Assure</strong><p>Evidence and first-payroll test</p></div></li></ol>
+  </section>`;
+}
+
+function decisionBand() {
+  return `<section class="matter-decision"><div><span class="eyebrow eyebrow--light">Decision required</span><h2>Approve the controlled July 1 implementation plan across seven properties.</h2><p>Four properties are implementation-ready. Two require benefit evidence. One requires final population reconciliation. The recommended path releases verified changes while holding only conditional treatment.</p></div><div class="matter-decision__meta"><span class="status status--critical">Due in 3 days</span><small>General Counsel · Jun 16</small><a class="button button--accent" href="/app/briefs/la-hotel-wage-2026/">Review decision ${icon('arrow-right')}</a></div></section>`;
+}
+
+function tabs() {
+  return `<nav class="matter-tabs" role="tablist" aria-label="Matter views"><button class="is-active" role="tab" aria-selected="true" data-matter-tab="analysis">Analysis <span>4 findings</span></button><button role="tab" aria-selected="false" data-matter-tab="actions">Actions & controls <span>7</span></button><button role="tab" aria-selected="false" data-matter-tab="evidence">Evidence <span>12</span></button><button role="tab" aria-selected="false" data-matter-tab="history">History <span>28</span></button></nav>`;
+}
+
+function scenarioWorkbench() {
+  return `<section class="panel scenario-workbench"><header class="panel-heading"><div><span class="eyebrow">Scenario SCN-2026-041-06</span><h2>Implementation impact model</h2></div><div class="table-actions"><span class="status status--info">Illustrative model</span><button data-toast="A new governed scenario version was created.">${icon('copy')} Save version</button></div></header><div class="scenario-grid">
+    <form class="scenario-inputs" onsubmit="return false">
+      <section class="input-section"><header><span>1</span><div><strong>Property scope</strong><small>Governed property records</small></div></header><label class="range-control"><span><strong>Properties included</strong><output data-scenario-properties-output>7</output></span><input type="range" min="3" max="10" value="7" data-scenario-properties data-scenario-input></label><label class="range-control"><span><strong>Covered employees</strong><output data-scenario-employees-output>842</output></span><input type="range" min="400" max="1400" step="10" value="842" data-scenario-employees data-scenario-input></label></section>
+      <section class="input-section"><header><span>2</span><div><strong>Benefit treatment</strong><small>Fact-dependent implementation</small></div></header><label class="radio-card"><input type="radio" name="structure" value="mixed" checked data-scenario-structure><span>${icon('layers')}<strong>Mixed treatment</strong><small>Verified credit where supported; cash residual elsewhere</small></span></label><label class="radio-card"><input type="radio" name="structure" value="cash" data-scenario-structure><span>${icon('calculator')}<strong>Full cash wage</strong><small>No health-benefit credit assumed</small></span></label><label class="radio-card"><input type="radio" name="structure" value="benefit" data-scenario-structure><span>${icon('shield')}<strong>Maximum supported credit</strong><small>Only after evidence acceptance</small></span></label><label class="range-control"><span><strong>Benefit value modeled</strong><output data-scenario-benefit-output>$6.28</output></span><input type="range" min="0" max="8" step=".01" value="6.28" data-scenario-benefit data-scenario-input></label></section>
+      <section class="input-section"><header><span>3</span><div><strong>Key fact gates</strong><small>No silent assumptions</small></div></header><label class="choice-row"><input type="checkbox" checked><span><strong>Locality and room count</strong><small>Verified · property master v18</small></span><b>Complete</b></label><label class="choice-row"><input type="checkbox"><span><strong>June carrier statement</strong><small>Requested · DTLA-01</small></span><b class="critical-text">Open</b></label><label class="choice-row"><input type="checkbox" checked><span><strong>Covered population</strong><small>842 current · one reconciliation</small></span><b class="warn-text">Conditional</b></label></section>
+    </form>
+    <div class="scenario-output"><div class="output-hero"><div><small>Illustrative annual operational impact</small><strong data-scenario-range>$1,036,000 – $1,385,000</strong><p>Range changes with property count, workforce, benefit evidence, and implementation structure.</p></div><span class="confidence-gauge" style="--score:74"><i></i><b data-scenario-readiness>74%</b><small>fact readiness</small></span></div>
+      <div class="output-breakdown"><div><span>Modeled midpoint</span><strong data-scenario-annual>$1,164,000</strong><small>Not a damages opinion</small></div><div><span>Properties ready</span><strong>4 / 7</strong><small>Three conditional states</small></div><div><span>Controls affected</span><strong>3</strong><small>Payroll · benefit · testing</small></div></div>
+      <div class="output-waterfall"><div class="waterfall-axis"><span>$0</span><span>$400K</span><span>$800K</span><span>$1.2M</span></div><div class="waterfall-row"><span>Wage-rate step</span><i><em style="width:68%;background:var(--blue-500)"></em></i><b>$782K</b></div><div class="waterfall-row"><span>Benefit residual</span><i><em style="width:27%;background:var(--teal-500)"></em></i><b>$311K</b></div><div class="waterfall-row"><span>Configuration + testing</span><i><em style="width:7%;background:var(--gold-500)"></em></i><b>$71K</b></div><div class="waterfall-row waterfall-row--total"><span>Modeled midpoint</span><i><em style="width:89%"></em></i><b data-scenario-annual>$1.164M</b></div></div>
+      <div class="model-contract">${icon('info')}<div><strong>Model contract</strong><p>Rule v3 · property facts v18 · calculation engine 0.9-prototype · two disclosed material facts · counsel review required.</p></div><button data-open-overlay="sources">Inspect logic and authority</button></div>
+    </div>
+  </div></section>`;
+}
+
+function findings() {
+  const findingsList = [
+    ['critical','Wage floor is confirmed for four properties','Authority and coverage facts are complete. Configuration may proceed.','Approved'],
+    ['warn','Benefit treatment remains conditional at DTLA-01','June carrier statement is required before any credit is applied.','Fact gap'],
+    ['good','Housekeeper workload obligations remain unchanged','The July wage step does not amend the existing workload-cap mechanics.','Approved'],
+    ['info','One employee population requires reconciliation','Payroll and HRIS counts differ by 17 workers at SM-02.','Review']
+  ];
+  const assumptions = [
+    ['verified','Locality and room count','Verified against property master v18.'],
+    ['gap','Qualifying benefit value','Open at DTLA-01 pending June carrier statement.'],
+    ['judgment','Materiality threshold','Counsel judgment: enterprise decision required due to systems and multi-property reach.'],
+    ['verified','Effective date','July 1, 2026 confirmed in primary authority.']
+  ];
+  return `<section class="matter-findings-grid"><article class="panel finding-register"><header class="panel-heading"><div><span class="eyebrow">Finding register</span><h2>Four governed findings</h2></div><button data-toast="A finding drafting workflow was opened.">${icon('plus')} Add</button></header><ol>${findingsList.map(([state,title,detail,status])=>`<li><span class="finding-state finding-state--${state}">${icon(state==='critical'?'alert':state==='warn'?'clock':state==='good'?'check-circle':'info')}</span><div><small>${status}</small><strong>${title}</strong><p>${detail}</p></div><b><span class="status status--${state==='critical'?'critical':state==='warn'?'warn':state==='good'?'good':'info'}">${status}</span></b></li>`).join('')}</ol></article>
+  <article class="panel assumptions-register"><header class="panel-heading"><div><span class="eyebrow">Fact and judgment ledger</span><h2>What the answer depends on</h2></div><button data-toast="The complete fact and judgment ledger would open here.">View all</button></header><div class="assumption-list">${assumptions.map(([state,title,detail])=>`<div class="assumption-row"><span>${icon(state==='verified'?'check':state==='gap'?'alert':'scale')}</span><div><strong>${title}</strong><small>${state==='verified'?'Enterprise fact':state==='gap'?'Missing fact':'Counsel judgment'}</small><p>${detail}</p></div><span class="assumption-state assumption-state--${state}">${state}</span></div>`).join('')}</div></article></section>`;
+}
+
+function propertyTable() {
+  return `<section class="panel property-impact-table"><header class="panel-heading panel-heading--table"><div><span class="eyebrow">Scope and action</span><h2>Property response register</h2></div><div class="table-actions"><button data-toast="Property filters opened.">${icon('filter')} Filter</button><button data-toast="Property response data exported.">${icon('download')} Export</button></div></header><div class="table-wrap"><table class="data-table"><thead><tr><th>Property</th><th>Fact readiness</th><th>Modeled impact</th><th>Control state</th><th>Owner</th><th></th></tr></thead><tbody>${properties.map((property,index)=>`<tr><td><a href="/app/properties/dtla-01/"><strong>${property.name}</strong><small>${property.id} · ${property.city}</small></a></td><td><span class="readiness"><i><em style="width:${property.readiness}%"></em></i><b>${property.readiness}%</b></span></td><td>${['$356K–$492K','$241K–$318K','$188K–$256K','$72K–$104K'][index]}</td><td><span class="status status--${index===0?'critical':index===1?'warn':index===2?'info':'good'}">${['Evidence gap','Reconciliation','Testing','Ready'][index]}</span></td><td>${['Marcus Lee','Priya Shah','Jamie Chen','Elena Ruiz'][index]}</td><td><a class="row-arrow" href="/app/properties/dtla-01/">${icon('arrow-right')}</a></td></tr>`).join('')}</tbody></table></div></section>`;
+}
+
+function otherPanels() {
+  return `<section class="matter-tab-panel" data-matter-panel="actions" hidden><article class="panel"><header class="panel-heading"><div><span class="eyebrow">Actions and controls</span><h2>Seven accountable work items</h2></div></header><div class="control-plan-grid"><article><span>${icon('calculator')}</span><small>Payroll</small><h3>Deploy rate tables</h3><p>Configure effective-dated property rates and reconcile the covered population.</p><span class="status status--warn">In progress</span></article><article><span>${icon('shield')}</span><small>Benefits</small><h3>Validate contribution</h3><p>Collect and accept June carrier evidence before using the credit.</p><span class="status status--critical">Blocked</span></article><article><span>${icon('activity')}</span><small>HRIS</small><h3>Run parallel payroll</h3><p>Test the first affected workweek and preserve all exception evidence.</p><span class="status status--info">Scheduled</span></article><article><span>${icon('users')}</span><small>Operations</small><h3>Communicate locally</h3><p>Issue property instructions and employee-facing rate communication.</p><span class="status status--neutral">Not started</span></article></div></article></section>
+  <section class="matter-tab-panel" data-matter-panel="evidence" hidden><article class="panel"><header class="panel-heading"><div><span class="eyebrow">Evidence register</span><h2>Twelve governed artifacts</h2></div></header><div class="evidence-register-grid">${[['source','Municipal code snapshot','Verified · hash retained'],['source','OWS implementation guidance','Verified · Jun 13'],['database','Property fact snapshot v18','7 properties'],['users','Covered worker population','One reconciliation'],['shield','Carrier contribution statement','Outstanding · DTLA-01'],['activity','Parallel payroll test','Scheduled Jun 21']].map(([ic,title,meta])=>`<article>${icon(ic)}<div><strong>${title}</strong><small>${meta}</small></div>${icon('chevron-right')}</article>`).join('')}</div></article></section>
+  <section class="matter-tab-panel" data-matter-panel="history" hidden><article class="panel"><header class="panel-heading"><div><span class="eyebrow">Immutable history</span><h2>Twenty-eight material events</h2></div></header><div class="table-wrap"><table class="data-table"><thead><tr><th>Time</th><th>Actor</th><th>Event</th><th>Record</th></tr></thead><tbody><tr><td>Jun 13 · 4:18 PM</td><td>Arthur K.</td><td>Decision version 4 submitted</td><td>DR-2026-018</td></tr><tr><td>Jun 13 · 2:40 PM</td><td>Priya S.</td><td>Payroll facts approved</td><td>FACTSET-018</td></tr><tr><td>Jun 13 · 11:05 AM</td><td>Marcus L.</td><td>Benefit evidence gap opened</td><td>EXC-2026-012</td></tr><tr><td>Jun 13 · 9:22 AM</td><td>System</td><td>Rule version 3 linked to seven properties</td><td>RULE-LA-HOTEL-3.0</td></tr></tbody></table></div></article></section>`;
+}
+
+function analysisPanel() {
+  return `<section class="matter-tab-panel" data-matter-panel="analysis">${scenarioWorkbench()}${findings()}${propertyTable()}</section>`;
+}
+
+function rail() {
+  return `<section class="rail-card rail-card--priority"><header><span>${icon('decision')}</span><span class="status status--critical">Decision due</span></header><small class="eyebrow eyebrow--light">General Counsel</small><h2>Approve the controlled implementation plan.</h2><p>The recommendation isolates unresolved facts without delaying verified wage changes.</p><div class="rail-deadline"><span>Due</span><strong>Jun 16 · 5:00 PM</strong></div><a class="button button--accent" href="/app/briefs/la-hotel-wage-2026/">Open decision record</a></section>
+  <section class="rail-card matter-confidence"><header><div><span class="eyebrow">Matter integrity</span><h2>Supportability</h2></div><span class="status status--good">Strong</span></header><div class="confidence-factor"><div><strong>Authority</strong><small>3 primary sources</small></div><b class="good-text">100%</b></div><div class="confidence-factor"><div><strong>Rule verification</strong><small>Version 3 approved</small></div><b class="good-text">100%</b></div><div class="confidence-factor"><div><strong>Fact readiness</strong><small>2 material gaps</small></div><b class="warn-text">74%</b></div><div class="confidence-factor"><div><strong>Model coverage</strong><small>9 fixtures · prototype</small></div><b class="warn-text">82%</b></div><button data-open-overlay="sources">Why this conclusion is supportable ${icon('arrow-right')}</button></section>
+  <section class="rail-card gap-card"><header><span>${icon('alert')}</span><div><small>Material fact gaps</small><strong>Two conditions remain open</strong></div></header><div><span>DTLA-01 benefit statement</span><b>Jun 18</b></div><div><span>SM-02 population reconciliation</span><b>Jun 17</b></div><button data-toast="The fact-resolution workflow opened.">Resolve facts</button></section>
+  <section class="rail-card activity-card"><header><div><span class="eyebrow">Activity</span><h2>Recent matter events</h2></div></header><ol><li><span class="activity-avatar">AK</span><div><strong>Decision version 4 submitted</strong><small>28 minutes ago</small></div></li><li><span class="activity-avatar activity-avatar--payroll">PS</span><div><strong>Population facts approved</strong><small>2 hours ago</small></div></li><li><span class="activity-avatar activity-avatar--benefits">ML</span><div><strong>Evidence request escalated</strong><small>4 hours ago</small></div></li><li><span class="activity-avatar activity-avatar--system">SY</span><div><strong>Rule v3 evaluation completed</strong><small>5 hours ago</small></div></li></ol><button data-matter-tab="history">View complete history ${icon('arrow-right')}</button></section>`;
+}
+
+module.exports = function renderMatter() {
+  const content = `${pageHeading()}${matterContext()}${decisionBand()}${tabs()}${analysisPanel()}${otherPanels()}`;
+  return appShell({ activeKey: 'matters', content, rail: rail() });
+};
