+  { id: 'TL-005', family: 'risk', label: 'Risk model', title: 'Exposure & penalty modeler', description: 'Model statutory remedies, penalties, assumptions, and scenario sensitivity without collapsing uncertainty into one number.', inputs: 'Population · period · findings', output: 'Range + assumptions', status: 'Counsel review', icon: 'scale' },
+  { id: 'TL-006', family: 'planning', label: 'Coverage', title: 'Fair workweek premium calculator', description: 'Apply covered-employer, worker, schedule-change, notice, and premium rules across hotel-relevant laws.', inputs: 'Employer · worker · schedule', output: 'Coverage + premium trace', status: 'Inspectable', icon: 'calendar' },
+  { id: 'TL-007', family: 'assessment', label: 'Property profile', title: 'Hotel compliance profiler', description: 'Turn property, location, room-count, workforce, and system facts into an effective-dated obligation profile.', inputs: 'Property passport facts', output: 'Applicable obligations', status: 'Fact dependent', icon: 'building' },
+  { id: 'TL-008', family: 'audit', label: 'Calculator', title: 'Tipped overtime calculator', description: 'Show state-aware weekly pay, credit assumptions, overtime math, and the consequence of a disallowed tip credit.', inputs: 'Rate · hours · credit · state', output: 'Step-by-step calculation', status: 'Inspectable', icon: 'calculator' },
+  { id: 'TL-009', family: 'audit', label: 'Calculator', title: 'Regular-rate calculator', description: 'Build a regular rate from multiple rates, bonuses, service charges, premiums, and alternative calculation methods.', inputs: 'Pay codes · hours · bonuses', output: 'Rate build + true-up', status: 'Inspectable', icon: 'calculator' },
+  { id: 'TL-010', family: 'assessment', label: 'Assessment', title: 'Exemption checker', description: 'Resolve salary basis, salary level, duties, state overlays, and commissioned-employee paths with disclosed judgment points.', inputs: 'Role · salary · duties', output: 'Layered determination', status: 'Counsel review', icon: 'briefcase' }
+];
+
+function stylesheetLinks() {
+  return ['tokens', 'base', 'components', 'public', 'app', 'responsive', 'v2']
+    .map(name => `<link rel="stylesheet" href="/assets/css/${name}.css">`).join('');
+}
+
+function baseHtml({ title, description, bodyClass }) {
+  return `<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width,initial-scale=1">
+  <meta name="description" content="${description}">
+  <meta name="theme-color" content="#07182f">
+  <meta name="robots" content="noindex,nofollow">
+  <title>${title}</title>
+  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
+  <link rel="manifest" href="/assets/manifest.webmanifest">
+  ${stylesheetLinks()}
+  <script src="/assets/js/app.js" defer></script>
+</head>
+<body class="${bodyClass}">`;
+}
+
+function publicBase(args) {
+  return baseHtml(args);
+}
+
+function appBase(args) {
+  return baseHtml(args);
+}
+
+module.exports = {
+  product,
+  publicNav,
+  appNav,
+  appRouteMeta,
+  changes,
+  properties,
+  controls,
+  sources,
+  jurisdictionRecords,
+  toolRecords,
+  publicBase,
+  appBase
+};
diff --git a/src/pages/brief.js b/src/pages/brief.js
new file mode 100644
index 0000000..688963e
--- /dev/null
+++ b/src/pages/brief.js
@@ -0,0 +1,260 @@
+'use strict';
+
+const { appShell } = require('../components/app-shell');
+const { icon } = require('../components/icons');
+
+function pageHeading() {
+  return `<header class="page-heading">
+    <div><span class="eyebrow">Decision record · DR-2026-018</span><h1>Approve one response. Preserve every reason.</h1><p>The executive artifact is rendered from the governed matter. Recommendation, alternatives, conditions, approvals, and provenance remain versioned together.</p></div>
+    <div class="page-heading__actions"><button class="button button--secondary" data-toast="A PDF snapshot was prepared from the current decision-record version.">${icon('download')} Export PDF</button><button class="button button--secondary" data-toast="The current decision-record link was copied.">${icon('share')} Share governed link</button></div>
+  </header>`;
+}
+
+function decisionHead() {
+  return `<section class="panel decision-record-head">
+    <div class="decision-record-head__identity">
+      <span class="record-seal">${icon('decision')}</span>
+      <div><span class="eyebrow">Executive decision · Version 4</span><h2>Los Angeles hotel wage and health-benefit response</h2><p>MTR-2026-041 · Seven properties · Prepared for General Counsel and Chief People Officer</p></div>
+    </div>
+    <div class="decision-record-head__state">
+      <span class="status status--critical" data-decision-state>Decision due in 3 days</span>
+      <small>Required before payroll lock · Jun 17, 2026</small>
+      <div><span>${icon('shield')} Source current</span><span>${icon('history')} 4 versions</span></div>
+    </div>
+    <ol class="approval-chain" aria-label="Approval chain">
+      <li class="is-complete"><span>${icon('check')}</span><div><small>Prepared</small><strong>Employment Counsel</strong><p>Jun 12 · 4:18 PM</p></div></li>
+      <li class="is-complete"><span>${icon('check')}</span><div><small>Validated</small><strong>Payroll + Benefits</strong><p>Jun 13 · 2:40 PM</p></div></li>
+      <li class="is-active"><span>${icon('decision')}</span><div><small>Decision</small><strong>General Counsel</strong><p>Due Jun 16</p></div></li>
+      <li><span>${icon('shield')}</span><div><small>Assurance</small><strong>Post-cutover review</strong><p>Scheduled Jul 8</p></div></li>
+    </ol>
+  </section>`;
+}
+
+function decisionDocument() {
+  return `<article class="panel decision-document" aria-label="Executive decision record">
+    <header class="decision-document__cover">
+      <div><span class="eyebrow eyebrow--light">Decision record</span><h2>Approve the controlled July 1 implementation plan.</h2><p>This recommendation reflects the current authority, rule, property, workforce, payroll, and benefit snapshots. One property-level benefit fact remains expressly conditional.</p></div>
+      <aside class="decision-document__ask"><small>Decision requested</small><strong>Authorize payroll implementation at seven properties, subject to the conditions in Section 4.</strong><span>Decision owner · General Counsel · Due Jun 16</span></aside>
+    </header>
+
+    <div class="decision-document__body">
+      <section class="record-section">
+        <span class="record-section__number">1</span>
+        <div><span class="eyebrow">Executive posture</span><h3>The ordinance applies across the Southern California cluster, but the response differs by property fact state.</h3><p>Four properties have complete facts and are ready for implementation. Two require evidence to substantiate the planned health-benefit credit. One requires an employee-population reconciliation before the final payroll delta is approved.</p>
+          <div class="executive-readout-grid">
+            <div><small>Properties in scope</small><strong>7</strong><span>4 ready · 3 conditional</span></div>
+            <div><small>Covered employees</small><strong>842</strong><span>Current governed population</span></div>
+            <div><small>Modeled annual impact</small><strong>$1.14M</strong><span>Illustrative · fact-sensitive</span></div>
+            <div><small>Open material gaps</small><strong>2</strong><span>Evidence + population</span></div>
+          </div>
+        </div>
+      </section>
+
+      <section class="record-section">
+        <span class="record-section__number">2</span>
+        <div><span class="eyebrow">Recommendation</span>
+          <div class="recommendation-callout"><span>${icon('check-circle')}</span><div><h3>Approve the controlled implementation plan.</h3><p>Release verified rate changes on schedule; hold only the conditional benefit-credit treatment and unreconciled population.</p></div></div>
+          <div class="recommendation-reasons">
+            <article><span>01</span><strong>Effective-date certainty</strong><p>The wage step is effective July 1 and supported by verified primary authority.</p></article>
+            <article><span>02</span><strong>Controlled exceptions</strong><p>The unresolved facts are separable and need not delay unaffected properties.</p></article>
+            <article><span>03</span><strong>System readiness</strong><p>Rate tables are configured and parallel testing is scheduled before payroll lock.</p></article>
+            <article><span>04</span><strong>Evidence path</strong><p>Every conditional treatment has an owner, deadline, and required proof artifact.</p></article>
+          </div>
+        </div>
+      </section>
+
+      <section class="record-section">
+        <span class="record-section__number">3</span>
+        <div><span class="eyebrow">Alternatives considered</span><h3>Three paths were evaluated against timing, cost, employee impact, and defensibility.</h3>
+          <div class="alternatives-table">
+            <div class="alternatives-table__head"><span>Alternative</span><span>Advantage</span><span>Material consequence</span><span>Status</span></div>
+            <div><strong>Controlled implementation</strong><span>Meets deadline while isolating open facts.</span><span>Requires precise exception and evidence governance.</span><span class="status status--good">Recommended</span></div>
+            <div><strong>Full cash-wage implementation</strong><span>Eliminates benefit-credit fact dependency.</span><span>Higher modeled annual cost and benefit duplication risk.</span><span class="status status--neutral">Available</span></div>
+            <div><strong>Defer all changes</strong><span>More time for reconciliation.</span><span>Misses the effective date and creates avoidable wage exposure.</span><span class="status status--critical">Rejected</span></div>
+          </div>
+        </div>
+      </section>
+
+      <section class="record-section">
+        <span class="record-section__number">4</span>
+        <div><span class="eyebrow">Conditions and guardrails</span><h3>Approval is effective only while these conditions remain satisfied.</h3>
+          <ol class="conditions-list">
+            <li><span>${icon('source')}</span><div><strong>Carrier evidence accepted by June 18</strong><p>Benefit credit remains blocked at DTLA-01 until the June contribution statement is validated.</p></div><b>Marcus Lee · Benefits</b></li>
+            <li><span>${icon('users')}</span><div><strong>Covered population reconciled</strong><p>Payroll and HRIS totals must agree before the final upload population is approved.</p></div><b>Priya Shah · Payroll</b></li>
+            <li><span>${icon('activity')}</span><div><strong>Parallel payroll test passes</strong><p>Every property must produce an exception-free test or an accepted, documented exception.</p></div><b>Jamie Chen · HRIS</b></li>
+            <li><span>${icon('shield')}</span><div><strong>Post-cutover assurance completed</strong><p>First payroll and evidence artifacts must be reviewed by July 8.</p></div><b>Legal Operations</b></li>
+          </ol>
+        </div>
+      </section>
+
+      <section class="record-section">
+        <span class="record-section__number">5</span>
+        <div><span class="eyebrow">Accountable plan</span><h3>The approval becomes work through named owners and controlled dates.</h3>
+          <div class="table-wrap"><table class="data-table owner-table"><thead><tr><th>Owner</th><th>Accountability</th><th>Due</th><th>State</th></tr></thead><tbody>
+            <tr><td><span class="owner-number">1</span><strong>Priya Shah</strong></td><td>Approve rate tables and population reconciliation</td><td>Jun 17</td><td><span class="status status--warn">In progress</span></td></tr>
+            <tr><td><span class="owner-number">2</span><strong>Marcus Lee</strong></td><td>Validate qualifying benefit contributions</td><td>Jun 18</td><td><span class="status status--critical">Evidence due</span></td></tr>
+            <tr><td><span class="owner-number">3</span><strong>Jamie Chen</strong></td><td>Execute parallel payroll tests</td><td>Jun 21</td><td><span class="status status--info">Scheduled</span></td></tr>
+            <tr><td><span class="owner-number">4</span><strong>Elena Ruiz</strong></td><td>Coordinate property communications and assurance</td><td>Jul 8</td><td><span class="status status--neutral">Not started</span></td></tr>
+          </tbody></table></div>
+        </div>
+      </section>
+
+      <section class="record-section">
+        <span class="record-section__number">6</span>
+        <div><span class="eyebrow">Provenance snapshot</span><h3>The basis for this decision is frozen with the approved version.</h3>
+          <div class="provenance-grid">
+            <article><span>${icon('source')}</span><small>Authority</small><strong>3 primary source versions</strong><p>Municipal code, implementation guidance, and state wage-payment provisions.</p><button data-open-overlay="sources">Inspect source chain</button></article>
+            <article><span>${icon('code')}</span><small>Rule</small><strong>LA hotel wage rule v3</strong><p>Coverage, wage, benefit, and effective-date logic approved Jun 13.</p><button data-toast="Rule specification opened.">Inspect rule trace</button></article>
+            <article><span>${icon('database')}</span><small>Fact snapshot</small><strong>Property facts v18</strong><p>Seven property records, workforce snapshot, systems, and benefit state.</p><button data-toast="Property fact snapshot opened.">Inspect facts</button></article>
+            <article><span>${icon('calculator')}</span><small>Scenario</small><strong>SCN-2026-041-06</strong><p>Inputs, assumptions, range, sensitivity, and model version preserved.</p><button data-toast="Scenario model opened.">Inspect model</button></article>
+          </div>
+          <div class="record-limit"><span>${icon('alert')}</span><p><strong>Known limitation:</strong> the modeled cost range remains illustrative until the benefit evidence and covered population are final. The legal effective date and wage-floor obligation are not conditional on those facts.</p></div>
+        </div>
+      </section>
+    </div>
+
+    <footer class="decision-document__signature">
+      <div><span class="eyebrow">Approval action</span><h3>Approve version 4 with the conditions above.</h3><p>Approval preserves this exact provenance snapshot and schedules the post-cutover review.</p></div>
+      <div class="signature-actions"><button class="button button--secondary" data-toast="The decision was returned with requested revisions.">Return with revisions</button><button class="button button--accent" data-approve-decision>${icon('check-circle')} Approve decision</button></div>
+    </footer>
+  </article>`;
+}
+
+function rail() {
+  return `<section class="rail-card rail-card--priority"><header><span>${icon('clock')}</span><span class="status status--critical">Due Jun 16</span></header><small class="eyebrow eyebrow--light">Decision owner</small><h2>General Counsel approval</h2><p>Payroll lock follows one day later. Conditions allow the unresolved evidence to remain isolated.</p><div class="rail-deadline"><span>Time remaining</span><strong>3 days</strong></div><button class="button button--accent" data-approve-decision>${icon('check-circle')} Approve version 4</button></section>
+  <section class="rail-card decision-summary-rail"><header><div><span class="eyebrow">At a glance</span><h2>Decision summary</h2></div></header><ul><li><span>Recommendation</span><strong>Controlled implementation</strong></li><li><span>Properties</span><strong>7</strong></li><li><span>Modeled impact</span><strong>$1.14M</strong></li><li><span>Conditions</span><strong>4</strong></li><li><span>Open fact gaps</span><strong class="critical-text">2</strong></li></ul></section>
+  <section class="rail-card record-integrity"><header><div><span class="eyebrow">Integrity</span><h2>Record completeness</h2></div><span class="status status--good">96%</span></header><ol><li><i class="good-dot"></i><div><strong>Authority current</strong><small>3 primary source versions</small></div></li><li><i class="good-dot"></i><div><strong>Rule approved</strong><small>Version 3 · Jun 13</small></div></li><li><i class="warn-dot"></i><div><strong>Facts conditional</strong><small>2 governed gaps</small></div></li><li><i class="good-dot"></i><div><strong>Owners assigned</strong><small>4 accountabilities</small></div></li><li><i class="good-dot"></i><div><strong>Revalidation defined</strong><small>Source, rule, fact, model</small></div></li></ol></section>
+  <section class="rail-card record-activity"><header><div><span class="eyebrow">Activity</span><h2>Version history</h2></div></header><ol><li><span class="activity-avatar">AK</span><div><strong>Version 4 submitted</strong><small>Jun 13 · 4:18 PM</small></div></li><li><span class="activity-avatar activity-avatar--payroll">PS</span><div><strong>Payroll figures validated</strong><small>Jun 13 · 2:40 PM</small></div></li><li><span class="activity-avatar activity-avatar--benefits">ML</span><div><strong>Benefit evidence gap recorded</strong><small>Jun 13 · 11:05 AM</small></div></li></ol></section>`;
+}
+
+module.exports = function renderBrief() {
+  return appShell({ activeKey: 'decision-records', content: `${pageHeading()}${decisionHead()}${decisionDocument()}`, rail: rail() });
+};
diff --git a/src/pages/changes.js b/src/pages/changes.js
new file mode 100644
index 0000000..fef7162
--- /dev/null
+++ b/src/pages/changes.js
@@ -0,0 +1,209 @@
+'use strict';
+
+const { appShell } = require('../components/app-shell');
+const { icon } = require('../components/icons');
+const { changes, properties } = require('../data/platform-data');
+
+function changeInbox() {
+  return `<aside class="change-inbox">
+    <header class="change-inbox__header"><div><span class="eyebrow">Signal queue</span><h2>Material changes</h2></div><span class="count-chip">4 open</span></header>
+    <div class="change-filters">
+      <button class="is-active" data-change-filter="all">All <b>12</b></button>
+      <button data-change-filter="critical">Critical <b>1</b></button>
+      <button data-change-filter="high">High <b>2</b></button>
+      <button data-change-filter="elevated">Elevated <b>4</b></button>
+    </div>
+    <label class="inbox-search">${icon('search')}<input aria-label="Filter legal changes" placeholder="Filter by jurisdiction or issue"></label>
+    <div class="change-inbox-list">
+      ${changes.map((item, index) => `<button class="change-inbox-item ${index === 0 ? 'is-active' : ''}" data-change-item data-materiality="${item.materiality}" data-title="${item.title}" data-meta="${item.id} · ${item.jurisdiction}">
+        <i class="change-inbox-item__marker materiality-marker--${item.materiality}"></i>
+        <span class="change-inbox-item__date"><strong>${item.date.split(' ')[1]}</strong><small>${item.date.split(' ')[0]}</small></span>
+        <span class="change-inbox-item__body"><small>${item.jurisdiction}</small><strong>${item.title}</strong><span>${item.meta}</span></span>
+        <span class="change-inbox-item__meta"><b class="status status--${item.materiality === 'critical' ? 'critical' : item.materiality === 'high' ? 'warn' : 'info'}">${item.status}</b><small>${item.id}</small></span>
+        ${icon('chevron-right')}
+      </button>`).join('')}
+    </div>
+    <footer><span>8 additional items monitored</span><button data-toast="The full monitored-change archive would open here.">View all ${icon('arrow-right')}</button></footer>
+  </aside>`;
+}
+
+function impactPath() {
+  return `<div class="impact-path" aria-label="Source to decision impact path">
+    <article><span>${icon('source')}</span><small>Authority</small><strong>Verified change</strong><p>Municipal code and official implementation guidance.</p><button data-open-overlay="sources">3 source versions</button></article>
+    <i>${icon('arrow-right')}</i>
+    <article class="impact-path__scope"><span>${icon('building')}</span><small>Portfolio</small><strong>7 likely properties</strong><p>Locality, room count, workforce, and benefit predicates.</p><a href="/app/properties/dtla-01/">Inspect scope</a></article>
+    <i>${icon('arrow-right')}</i>
+    <article class="impact-path__controls"><span>${icon('shield')}</span><small>Operations</small><strong>3 controls affected</strong><p>Rate tables, benefit substantiation, and parallel testing.</p><a href="/app/controls/">Open controls</a></article>
+    <i>${icon('arrow-right')}</i>
+    <article class="impact-path__decision"><span>${icon('decision')}</span><small>Decision</small><strong>Approval due Jun 16</strong><p>Controlled implementation with evidence conditions.</p><a href="/app/briefs/la-hotel-wage-2026/">Open decision</a></article>
+  </div>`;
+}
+
+function changeDetail() {
+  return `<article class="change-detail" data-change-detail>
+    <header class="change-detail__header">
+      <div class="change-detail__identity"><i class="materiality-dot--critical"></i><div><small data-change-detail-meta>CHG-2026-118 · California · Los Angeles</small><h2 data-change-detail-title>Hotel wage and health-benefit step takes effect July 1</h2></div></div>
+      <div class="change-detail__actions"><button class="icon-button" aria-label="Share change" data-toast="Change record link copied.">${icon('share')}</button><button class="button button--secondary button--small" data-open-overlay="sources">${icon('source')} Source chain</button></div>
+    </header>
+    <section class="change-verdict"><div><span class="eyebrow">Legal delta</span><h3>The hotel wage floor increases and the health-benefit differential must be resolved property by property.</h3></div><div class="change-verdict__status"><span class="status status--critical">Material response required</span><small>Effective in 18 days</small></div></section>
+    <section class="change-facts">
+      <div><small>Published</small><strong>Jun 13, 2026</strong><span>${icon('check-circle')} Verified</span></div>
+      <div><small>Effective</small><strong>Jul 1, 2026</strong><span>${icon('clock')} 18 days</span></div>
+      <div><small>Primary authority</small><strong>LAMC § 187.02</strong><span>${icon('source')} 3 passages</span></div>
+      <div><small>Source health</small><strong>Current</strong><span class="good-text">${icon('shield')} No conflict</span></div>
+    </section>
+    <section class="impact-map"><header><div><span class="eyebrow">Enterprise consequence</span><h3>One legal change. Four governed transitions.</h3></div><span>Current as of Jun 13 · property facts v18</span></header>${impactPath()}</section>
+    <section class="scope-differential"><header><div><span class="eyebrow">Property scope</span><h3>Likely reach and remaining fact resolution</h3></div><button data-toast="All seven scoped properties would be shown.">View all 7 properties</button></header>
+      <div class="table-wrap"><table class="data-table data-table--compact"><thead><tr><th>Property</th><th>Coverage</th><th>Material condition</th><th>Fact state</th><th>Response</th></tr></thead><tbody>
+        ${properties.map((property, index) => `<tr><td><a href="/app/properties/dtla-01/"><strong>${property.name}</strong><small>${property.id} · ${property.rooms} rooms</small></a></td><td><span class="status status--${index === 0 ? 'critical' : index === 1 ? 'warn' : index === 2 ? 'info' : 'good'}">${index < 3 ? 'Covered' : 'Review'}</span></td><td>${index === 0 ? 'Benefit credit not substantiated' : index === 1 ? 'Population reconciliation' : index === 2 ? 'Rate table approval' : 'No material gap'}</td><td><span class="readiness"><i><em style="width:${property.readiness}%"></em></i><b>${property.readiness}%</b></span></td><td><a class="row-arrow" href="/app/matters/la-hotel-wage-2026/">${icon('arrow-right')}</a></td></tr>`).join('')}
+      </tbody></table></div>
+    </section>
+    <section class="decision-conversion"><div><span>${icon('matter')}</span><div><small>Governed response</small><h3>MTR-2026-041 · Los Angeles hotel wage step</h3><p>Scope, facts, analysis, controls, owners, evidence, and decision remain on one record.</p></div></div><a class="button button--light" href="/app/matters/la-hotel-wage-2026/">Open matter ${icon('arrow-right')}</a></section>
+  </article>`;
+}
+
+function rail() {
+  return `<section class="rail-card rail-card--priority"><header><span>${icon('clock')}</span><span class="status status--critical">Decision due</span></header><small class="eyebrow eyebrow--light">Next required action</small><h2>Approve the implementation posture.</h2><p>General Counsel approval is required before the first payroll configuration lock.</p><div class="rail-deadline"><span>Due</span><strong>Jun 16 · 5:00 PM</strong></div><a class="button button--accent" href="/app/briefs/la-hotel-wage-2026/">Open decision record</a></section>
+  <section class="rail-card"><header><div><span class="eyebrow">Materiality</span><h2>Why this is high priority</h2></div><span class="status status--critical">92 / 100</span></header><div class="materiality-model"><ul><li><span>Portfolio reach</span><strong>7 / 34 properties</strong></li><li><span>Effective-date proximity</span><strong>18 days</strong></li><li><span>Systems affected</span><strong>Payroll + benefits</strong></li><li><span>Open facts</span><strong class="critical-text">2 material</strong></li><li><span>Decision required</span><strong>Yes</strong></li></ul><p>The score is a transparent triage index—not a legal conclusion.</p></div></section>
+  <section class="rail-card"><header><div><span class="eyebrow">Horizon</span><h2>Change calendar</h2></div></header><div class="horizon-chart"><span><b>4</b><i class="critical" style="height:78%"></i><small>0–30d</small></span><span><b>7</b><i class="warn" style="height:55%"></i><small>31–60d</small></span><span><b>5</b><i style="height:40%"></i><small>61–90d</small></span><span><b>3</b><i class="good" style="height:25%"></i><small>90+d</small></span><span><b>8</b><i class="neutral" style="height:18%"></i><small>Watch</small></span></div></section>`;
+}
+
+function pageHeading() {
+  return `<header class="page-heading"><div><span class="eyebrow">Change intelligence</span><h1>Turn legal change into accountable response.</h1><p>Every development is tied to its authority, effective date, likely portfolio reach, control impact, decision requirement, and remaining fact gaps.</p></div><div class="page-heading__actions"><button class="button button--secondary" data-toast="Monitoring configuration opened.">${icon('settings')} Monitoring</button><button class="button button--primary" data-toast="A new legal change intake was opened.">${icon('plus')} Add change</button></div></header>`;
+}
+
+module.exports = function renderChanges() {
+  const content = `${pageHeading()}<section class="panel change-workspace">${changeInbox()}${changeDetail()}</section>`;
+  return appShell({ activeKey: 'changes', content, rail: rail() });
+};
diff --git a/src/pages/controls.js b/src/pages/controls.js
new file mode 100644
index 0000000..e2e76e2
--- /dev/null
+++ b/src/pages/controls.js
@@ -0,0 +1,227 @@
+'use strict';
+
+const { appShell } = require('../components/app-shell');
+const { icon } = require('../components/icons');
+const { controls } = require('../data/platform-data');
+
+function heading() {
+  return `<header class="page-heading"><div><span class="eyebrow">Control assurance</span><h1>Turn obligations into controls. Turn controls into proof.</h1><p>A policy is not evidence. This registry distinguishes obligation, control design, implementation, operation, testing, accepted evidence, exceptions, and remediation.</p></div><div class="page-heading__actions"><button class="button button--secondary" data-toast="The evidence-request composer was opened.">${icon('upload')} Request evidence</button><button class="button button--primary" data-toast="A new control design workflow was opened.">${icon('plus')} Add control</button></div></header>`;
+}
+
+function hero() {
+  return `<section class="control-assurance-hero">
+    <div class="control-assurance-hero__score"><svg viewBox="0 0 42 42"><circle cx="21" cy="21" r="15.9"/><circle class="score" cx="21" cy="21" r="15.9" pathLength="100"/></svg><span><strong>87%</strong><small>Assurance coverage</small></span></div>
+    <div class="control-assurance-hero__copy"><span class="eyebrow eyebrow--light">Portfolio assurance posture</span><h2>Most obligations are controlled. Three conditions require action.</h2><p>Coverage is weighted by materiality, evidence currency, open exceptions, and independent testing. The score does not represent legal compliance.</p><div><span class="status status--good">42 operating</span><span class="status status--warn">5 review</span><span class="status status--critical">3 exceptions</span></div></div>
+    <div class="control-assurance-hero__facts"><span><small>Current evidence</small><strong>91%</strong><b>+4 pts this month</b></span><span><small>Open exceptions</small><strong>3</strong><b>2 material</b></span><span><small>Tests due · 30d</small><strong>9</strong><b>4 scheduled</b></span></div>
+  </section>`;
+}
+
+function domainCards() {
+  const domains = [
+    ['Payroll', 91, '2 exceptions', '14 controls'],
+    ['Timekeeping', 94, 'No material exception', '11 controls'],
+    ['Benefits', 76, '1 material evidence gap', '7 controls'],
+    ['Scheduling', 89, '1 exception', '6 controls'],
+    ['Tips & service charges', 84, '2 reviews', '9 controls'],
+    ['Workload & staffing', 88, '1 review', '5 controls']
+  ];
+  return `<section class="control-domain-grid">${domains.map(([name, score, note, count]) => `<article><div class="domain-card__score" style="--score:${score}"><svg viewBox="0 0 42 42"><circle cx="21" cy="21" r="15.9"/><circle class="score" cx="21" cy="21" r="15.9" pathLength="100"/></svg><strong>${score}%</strong></div><div><small>${count}</small><h3>${name}</h3><p>${note}</p></div><a href="#control-register" aria-label="View ${name} controls">${icon('arrow-right')}</a></article>`).join('')}</section>`;
+}
+
+function matrix() {
+  return `<section class="panel control-matrix"><header class="panel-heading"><div><span class="eyebrow">Coverage matrix</span><h2>Obligation-to-control coverage</h2><p>Design, operation, evidence, assurance, and exception status remain separate.</p></div><div class="matrix-legend"><span><i class="good"></i> Effective</span><span><i class="warn"></i> Review</span><span><i class="critical"></i> Exception</span><span><i class="neutral"></i> Not tested</span></div></header>
+    <div class="matrix-wrap"><div class="matrix-head"><span>Obligation</span><span>Design</span><span>Operate</span><span>Evidence</span><span>Assure</span><span>Accountable owner</span></div>
+      <div class="matrix-row"><strong>LA hotel wage floor<small>RULE-LA-HOTEL-3.0</small></strong><button class="matrix-cell matrix-cell--good" data-toast="Control design is approved.">A</button><button class="matrix-cell matrix-cell--warn" data-toast="Operating test is in progress.">IP</button><button class="matrix-cell matrix-cell--warn" data-toast="One evidence item remains outstanding.">4/5</button><button class="matrix-cell matrix-cell--neutral" data-toast="Assurance is scheduled for July 8.">Jul 8</button><span>Priya Shah · Payroll</span></div>
+      <div class="matrix-row"><strong>Health-benefit differential<small>RULE-LA-HB-3.0</small></strong><button class="matrix-cell matrix-cell--good">A</button><button class="matrix-cell matrix-cell--critical">EX</button><button class="matrix-cell matrix-cell--critical">Gap</button><button class="matrix-cell matrix-cell--neutral">—</button><span>Marcus Lee · Benefits</span></div>
+      <div class="matrix-row"><strong>Housekeeper workload cap<small>RULE-LA-HK-2.2</small></strong><button class="matrix-cell matrix-cell--good">A</button><button class="matrix-cell matrix-cell--good">OP</button><button class="matrix-cell matrix-cell--good">7/7</button><button class="matrix-cell matrix-cell--good">Pass</button><span>Elena Ruiz · Operations</span></div>
+      <div class="matrix-row"><strong>Predictive-schedule premium<small>RULE-CHI-FWW-1.4</small></strong><button class="matrix-cell matrix-cell--good">A</button><button class="matrix-cell matrix-cell--warn">RV</button><button class="matrix-cell matrix-cell--good">6/6</button><button class="matrix-cell matrix-cell--warn">Review</button><span>Jamie Chen · HRIS</span></div>
+      <div class="matrix-row"><strong>Service-charge classification<small>RULE-SVC-4.1</small></strong><button class="matrix-cell matrix-cell--warn">RV</button><button class="matrix-cell matrix-cell--good">OP</button><button class="matrix-cell matrix-cell--warn">8/9</button><button class="matrix-cell matrix-cell--neutral">Jun 27</button><span>Noah Williams · F&B</span></div>
+    </div>
+  </section>`;
+}
+
+function register() {
+  return `<section class="panel control-register" id="control-register"><header class="panel-heading panel-heading--table"><div><span class="eyebrow">Control registry</span><h2>50 governed controls</h2></div><div class="table-actions"><label>${icon('search')}<input aria-label="Filter controls" placeholder="Filter controls"></label><select aria-label="Filter by domain"><option>All domains</option><option>Payroll</option><option>Benefits</option><option>Timekeeping</option></select><button data-toast="Control filters opened.">${icon('filter')} Filters</button></div></header>
+    <div class="table-wrap"><table class="data-table"><thead><tr><th>Control</th><th>Domain</th><th>Coverage</th><th>Evidence</th><th>Exceptions</th><th>Next test</th><th></th></tr></thead><tbody>
+      ${controls.map((control, index) => `<tr data-control-row data-control-title="${control.name}" data-control-id="${control.id}"><td><div class="control-name"><span class="control-icon control-icon--${index}">${icon(index === 0 ? 'calculator' : index === 1 ? 'shield' : index === 2 ? 'clock' : index === 3 ? 'calendar' : 'users')}</span><span><strong>${control.name}</strong><small>${control.id} · ${index === 0 ? 'Automated preventive' : index === 1 ? 'Hybrid preventive' : 'Detective review'}</small></span></div></td><td>${control.domain}</td><td><span class="coverage-meter"><i><em style="width:${control.coverage}%"></em></i><b>${control.coverage}%</b></span></td><td><span class="status status--${control.evidence === 'Current' ? 'good' : control.evidence === 'Gap' ? 'critical' : 'warn'}">${control.evidence}</span></td><td>${control.exceptions ? `<span class="${control.exceptions > 1 ? 'critical-text' : 'warn-text'}">${control.exceptions} open</span>` : '<span class="good-text">None</span>'}</td><td>${control.nextTest}</td><td><button class="row-arrow" aria-label="Open control">${icon('arrow-right')}</button></td></tr>`).join('')}
+    </tbody></table></div><footer class="table-footer"><span>Showing 5 of 50 controls</span><a href="#" data-toast="The complete control registry would open here.">View complete registry ${icon('arrow-right')}</a></footer></section>`;
+}
+
+function cycle() {
+  return `<section class="panel assurance-cycle"><header class="panel-heading"><div><span class="eyebrow">Assurance lifecycle</span><h2>From legal obligation to operating proof</h2></div><button data-open-overlay="sources">Inspect evidence contract</button></header><ol><li><span>${icon('source')}</span><small>01 · Obligation</small><strong>Define the outcome</strong><p>Rule, scope, effective date, and legal owner.</p></li><li><span>${icon('settings')}</span><small>02 · Design</small><strong>Specify the control</strong><p>Owner, cadence, population, system, and procedure.</p></li><li><span>${icon('activity')}</span><small>03 · Operate</small><strong>Execute the control</strong><p>Performance event with retained metadata.</p></li><li><span>${icon('database')}</span><small>04 · Evidence</small><strong>Collect operating proof</strong><p>Immutable artifact, period, population, and hash.</p></li><li><span>${icon('shield')}</span><small>05 · Assure</small><strong>Test and accept</strong><p>Independent result, exception, remediation, and retest.</p></li></ol></section>`;
+}
+
+function controlDrawer() {
+  return `<div class="control-detail-backdrop" data-overlay="control-detail" hidden><aside class="control-detail-drawer" data-control-drawer role="dialog" aria-modal="true" aria-labelledby="control-drawer-title"><header><div><span class="eyebrow" data-control-drawer-id>CTL-PAY-014</span><h2 id="control-drawer-title" data-control-drawer-title>Hotel wage rate table deployment</h2></div><button data-close-overlay aria-label="Close control detail">${icon('close')}</button></header><section class="control-detail-state"><div><small>Operating status</small><strong>In progress</strong><p>Parallel test scheduled before production payroll lock.</p></div><span class="status status--warn">1 exception</span></section><section><span class="eyebrow">Control objective</span><h3>Every covered worker receives the effective property wage and any residual benefit amount on the first applicable payroll.</h3></section><section><span class="eyebrow">Design</span><div class="control-test"><span>${icon('code')}</span><div><strong>Automated configuration + independent review</strong><p>Effective-dated rate table, covered-population reconciliation, two-person approval, and test payroll evidence.</p></div></div></section><section><span class="eyebrow">Evidence required</span><ul class="feature-list"><li>${icon('check-circle')} Approved rate table export</li><li>${icon('check-circle')} Covered-population reconciliation</li><li>${icon('alert')} DTLA-01 benefit evidence</li><li>${icon('clock')} Parallel payroll result</li></ul></section><footer><button class="button button--secondary" data-toast="Control work history opened.">View history</button><button class="button button--primary" data-toast="Evidence request sent to the accountable owner.">Request evidence</button></footer></aside></div>`;
+}
+
+function rail() {
+  return `<section class="rail-card rail-card--priority"><header><span>${icon('alert')}</span><span class="status status--critical">Material exception</span></header><small class="eyebrow eyebrow--light">CTL-BEN-006</small><h2>Benefit credit evidence is incomplete.</h2><p>DTLA-01 cannot use the planned credit until the carrier contribution statement is accepted.</p><div class="rail-deadline"><span>Evidence due</span><strong>Jun 18</strong></div><button class="button button--accent" data-toast="Evidence request opened for CTL-BEN-006.">Open exception</button></section>
+  <section class="rail-card"><header><div><span class="eyebrow">Test calendar</span><h2>June assurance</h2></div><button class="icon-button" aria-label="Open assurance calendar" data-toast="The full assurance calendar opened.">${icon('calendar')}</button></header><div class="calendar-month"><strong>June 2026</strong><span><b>M</b><b>T</b><b>W</b><b>T</b><b>F</b><b>S</b><b>S</b></span><div>${Array.from({length:30},(_,i)=>`<b class="${i+1===13?'today':i+1===18||i+1===20||i+1===27?'has-event':''}">${i+1}</b>`).join('')}</div></div></section>
+  <section class="rail-card"><header><div><span class="eyebrow">Evidence health</span><h2>Portfolio evidence</h2></div><span class="status status--good">91%</span></header><div class="confidence-factor"><div><strong>Current and accepted</strong><small>246 evidence items</small></div><b class="good-text">91%</b></div><div class="confidence-factor"><div><strong>Expiring in 30 days</strong><small>17 evidence items</small></div><b class="warn-text">6%</b></div><div class="confidence-factor"><div><strong>Rejected or missing</strong><small>8 evidence items</small></div><b class="critical-text">3%</b></div></section>`;
+}
+
+module.exports = function renderControls() {
+  const content = `${heading()}${hero()}${domainCards()}${matrix()}${register()}${cycle()}${controlDrawer()}`;
+  return appShell({ activeKey: 'controls', content, rail: rail() });
+};
diff --git a/src/pages/home.js b/src/pages/home.js
new file mode 100644
index 0000000..6e0cb1a
--- /dev/null
+++ b/src/pages/home.js
@@ -0,0 +1,195 @@
+'use strict';
+
+const { publicShell } = require('../components/public-shell');
+const { icon } = require('../components/icons');
+const { product } = require('../data/platform-data');
+
+function hero() {
+  return `<section class="home-hero">
+    <div class="hero-aurora"></div><div class="hero-grid"></div>
+    <div class="home-hero__inner">
+      <div class="home-hero__copy">
+        <span class="hero-kicker"><i></i> Hospitality wage-and-hour intelligence</span>
+        <h1>See the change.<br>Know the impact.<br><em>Prove the response.</em></h1>
+        <p>The control plane that connects verified legal authority to your properties, people, payroll systems, accountable actions, executive decisions, and operating evidence.</p>
+        <div class="hero-actions"><a class="button button--accent button--large" href="/app/">Enter portfolio command ${icon('arrow-right')}</a><a class="button button--ghost-light button--large" href="#how-it-works">See how the system works</a></div>
+        <div class="hero-trustline"><span>${icon('shield')} Source governed</span><span>${icon('calendar')} Effective dated</span><span>${icon('source')} Passage cited</span><span>${icon('eye')} Gaps disclosed</span></div>
+      </div>
+      <div class="hero-system" aria-label="Illustrative enterprise matter flow">
+        <div class="hero-system__top"><span><i></i> Active enterprise matter</span><button data-open-overlay="command">Ask across this matter ${icon('spark')}</button></div>
+        <header class="hero-matter-head"><div><span>MTR-2026-041 · Southern California</span><h2>Los Angeles hotel wage step</h2><p>Effective July 1, 2026 · 7 properties under review</p></div><span class="status status--critical">Decision due</span></header>
+        <div class="system-thread"><i></i><i></i><i></i><i></i></div>
+        <ol class="hero-flow">
+          <li class="hero-flow__authority"><span class="flow-icon">${icon('source')}</span><div><small>Verified authority</small><strong>Hotel wage and benefit step</strong><p>Primary law · effective date · approved rule version</p></div><b>Current</b></li>
+          <li class="hero-flow__scope"><span class="flow-icon">${icon('building')}</span><div><small>Portfolio applicability</small><strong>7 properties · 842 employees</strong><p>Location · room count · workforce · benefit facts</p></div><b>2 gaps</b></li>
+          <li class="hero-flow__controls"><span class="flow-icon">${icon('shield')}</span><div><small>Accountable response</small><strong>3 controls · 4 owners</strong><p>Payroll · benefits · testing · evidence</p></div><b>In progress</b></li>
+          <li class="hero-flow__decision"><span class="flow-icon">${icon('decision')}</span><div><small>Executive decision</small><strong>Controlled implementation</strong><p>Recommendation · conditions · provenance</p></div><b>Due Jun 16</b></li>
+        </ol>
+        <footer class="hero-system__footer"><span><strong>96%</strong><small>record completeness</small></span><span><strong>3</strong><small>primary authorities</small></span><span><strong>1</strong><small>disclosed fact gap</small></span><a href="/app/matters/la-hotel-wage-2026/">Open governed matter ${icon('arrow-right')}</a></footer>
+      </div>
+    </div>
+    <div class="hero-proof"><div class="proof-metric"><strong>${product.corpus.issueBriefs}</strong><span>Deep issue briefs</span><small>Curated legal intelligence</small></div><div class="proof-metric"><strong>${product.corpus.jurisdictions}</strong><span>State + D.C. guides</span><small>Effective-dated comparisons</small></div><div class="proof-metric"><strong>${product.corpus.hotelLaws}</strong><span>Hotel-specific laws</span><small>Wage, benefit, workload, retention</small></div><div class="proof-metric"><strong>${product.corpus.tools}</strong><span>Inspectable workflows</span><small>Inputs, logic, sources, outputs</small></div></div>
+  </section>`;
+}
+
+function thesis() {
+  return `<section class="home-thesis" id="how-it-works"><header class="section-lead section-lead--split"><div><span class="eyebrow">The operating model</span><h2>Legal intelligence is only useful when it survives the handoff.</h2></div><p>A development should not be summarized in one system, analyzed in another, assigned in email, briefed in slides, and proven in a shared drive. One governed record should carry the law, facts, analysis, ownership, decision, and evidence.</p></header>
+    <div class="consequence-chain">
+      <article><span>01</span>${icon('signal')}<h3>Detect change</h3><p>Capture the source, identify the changed rule, preserve the version, and rank materiality.</p><small>Authority graph</small></article>
+      <article><span>02</span>${icon('building')}<h3>Resolve reach</h3><p>Apply effective-dated law to property, workforce, pay, benefit, schedule, and system facts.</p><small>Applicability engine</small></article>
+      <article><span>03</span>${icon('matter')}<h3>Govern response</h3><p>Carry findings into owners, actions, controls, evidence requests, and approved exceptions.</p><small>Matter graph</small></article>
+      <article><span>04</span>${icon('decision')}<h3>Preserve decision</h3><p>Give leadership a concise recommendation without severing it from its legal and factual basis.</p><small>Decision record</small></article>
+    </div>
+  </section>`;
+}
+
+function controlPlane() {
+  return `<section class="control-plane-section"><div class="control-plane-copy"><span class="eyebrow eyebrow--light">The control plane</span><h2>One record from authority to assurance.</h2><p>Every experience is a view of the same governed object graph—not a disconnected dashboard, calculator, article, or slide deck.</p><ul class="feature-list feature-list--light"><li>${icon('check-circle')} One rule version across every surface</li><li>${icon('check-circle')} One effective-dated property fact model</li><li>${icon('check-circle')} Deterministic logic separated from counsel judgment</li><li>${icon('check-circle')} Approved decisions linked to operating proof</li><li>${icon('check-circle')} Revalidation when a dependency changes</li></ul><a class="text-link text-link--light" href="/methodology/">Inspect the evidence and governance standard ${icon('arrow-right')}</a></div>
+    <div class="control-plane-window">
+      <div class="window-chrome"><span><i></i><i></i><i></i></span><strong>North America portfolio</strong><small>Current through Jun 13, 2026</small></div>
+      <div class="window-shell"><aside><span class="mini-logo">HWL</span><span class="active">${icon('grid')} Overview</span><span>${icon('signal')} Changes</span><span>${icon('matter')} Matters</span><span>${icon('shield')} Controls</span><span>${icon('building')} Portfolio</span><span>${icon('book')} Research</span></aside>
+        <main class="window-main"><header class="window-heading"><div><small>PORTFOLIO COMMAND</small><h3>What requires attention now?</h3></div><button>${icon('spark')} Ask</button></header>
+          <div class="window-kpis"><span><small>Material decisions</small><strong>3</strong><i>2 due in 7 days</i></span><span><small>Open matters</small><strong>7</strong><i>4 on track</i></span><span><small>Control assurance</small><strong>87%</strong><i>+5 pts</i></span></div>
+          <div class="window-grid"><article class="window-matter"><header><span>MATTER MTR-2026-041</span><b>Decision due</b></header><h4>Los Angeles hotel wage step</h4><p>7 properties · 842 employees · July 1 effective date</p><div class="mini-lifecycle"><span class="done">Assess</span><span class="active">Decide</span><span>Implement</span><span>Assure</span></div><footer><span>1 fact gap · 3 controls</span><a href="/app/matters/la-hotel-wage-2026/">Open matter →</a></footer></article><article class="window-exposure"><header><span>PORTFOLIO REACH</span><span>34 properties</span></header><div class="exposure-row"><span>Southern California</span><i><em style="width:88%"></em></i><b>7</b></div><div class="exposure-row"><span>Northeast</span><i><em style="width:56%"></em></i><b>5</b></div><div class="exposure-row"><span>Pacific Northwest</span><i><em style="width:41%"></em></i><b>4</b></div></article><article class="window-actions"><header><span>EXECUTIVE ACTIONS</span><b>3 due</b></header><div><i class="critical-dot"></i><span><strong>Approve wage-step response</strong><small>Due Jun 16 · General Counsel</small></span></div><div><i class="warn-dot"></i><span><strong>Accept benefit evidence</strong><small>Due Jun 18 · Benefits</small></span></div></article></div>
+        </main>
+      </div>
+    </div>
+  </section>`;
+}
+
+function audiences() {
+  return `<section class="audience-section"><header class="section-lead"><span class="eyebrow">One system · role-relevant emphasis</span><h2>Shared truth without shared noise.</h2><p>Every leader sees the depth appropriate to the decision they own. No role gets a divergent version of the law or facts.</p></header><div class="audience-grid">
+    <article><span>${icon('decision')}</span><small>General Counsel</small><h3>Material posture and decisions</h3><p>See what changed, which obligations are material, what judgment is required, and whether the response remains defensible.</p><a href="/app/">Open portfolio command ${icon('arrow-right')}</a></article>
+    <article><span>${icon('book')}</span><small>Employment counsel</small><h3>Facts, analysis, and authority</h3><p>Resolve scope, inspect every proposition, model alternatives, approve findings, and draft the decision record.</p><a href="/app/matters/la-hotel-wage-2026/">Open governed matter ${icon('arrow-right')}</a></article>
+    <article><span>${icon('calculator')}</span><small>Payroll + HR</small><h3>Configuration and accountable action</h3><p>Translate approved findings into effective-dated rate tables, worker populations, testing, and communications.</p><a href="/app/controls/">Open control assurance ${icon('arrow-right')}</a></article>
+    <article><span>${icon('building')}</span><small>Hotel operations</small><h3>Property obligations and proof</h3><p>Know which local requirements apply, what process changes, who owns them, and what evidence must be retained.</p><a href="/app/properties/dtla-01/">Open property intelligence ${icon('arrow-right')}</a></article>
+  </div></section>`;
+}
+
+function evidence() {
+  const layers = [
+    ['01','Primary authority','Statutes, regulations, ordinances, cases, and official publications','Immutable source'],
+    ['02','Official guidance','Agency rules, FAQs, notices, and enforcement materials','Versioned guidance'],
+    ['03','Canonical analysis','Approved explanations, issue structures, and interpretation notes','Attorney reviewed'],
+    ['04','Enterprise facts','Property, workforce, payroll, benefits, schedule, and policy data','Provenance + freshness'],
+    ['05','Deterministic logic','Coverage predicates, calculations, branch traces, and tests','Reproducible'],
+    ['06','Counsel judgment','Interpretation, materiality, recommendation, and conditions','Named approval'],
+    ['07','Response evidence','Configuration, tests, communications, and accepted proof','Assured operation']
+  ];
+  return `<section class="evidence-standard-section"><div class="evidence-standard__copy"><span class="eyebrow">Trust architecture</span><h2>Authority is a chain—not a badge.</h2><p>The platform distinguishes every layer that supports a conclusion. Source text, enterprise fact, calculation, legal judgment, and response evidence never collapse into one opaque “confidence score.”</p><a class="button button--primary" href="/methodology/">Read the evidence standard ${icon('arrow-right')}</a></div><ol class="evidence-layers">${layers.map(([n,title,desc,status])=>`<li><span>${n}</span><div><strong>${title}</strong><p>${desc}</p></div><b>${status}</b></li>`).join('')}</ol></section>`;
+}
+
+function research() {
+  return `<section class="research-foundation"><header class="research-foundation__head"><div><span class="eyebrow">Public authority foundation</span><h2>Deep research remains the visible foundation.</h2></div><p>The public site continues to carry rigorous issue, jurisdiction, development, methodology, and tool content. The enterprise control plane adds property applicability and governed response without weakening public access.</p></header><div class="research-foundation__grid"><article class="research-feature"><span>Featured intelligence</span><h3>Hotel ordinances are no longer edge cases.</h3><p>Local wage floors, health-benefit differentials, workload caps, panic-button obligations, scheduling rules, recall rights, and retention duties increasingly determine the hotel operating model.</p><footer><span>Updated Jun 13, 2026</span><b>${icon('source')} 28 primary authorities</b></footer></article><div class="research-stack"><a href="/intelligence/"><span>${icon('book')}</span><div><small>Issue intelligence</small><strong>Eighteen structured issue briefs</strong><p>Direct answers, deeper analysis, operational implications, and sources.</p></div>${icon('arrow-right')}</a><a href="/jurisdictions/"><span>${icon('map')}</span><div><small>Jurisdictions</small><strong>All 50 states + D.C.</strong><p>Effective-dated rules, local overlays, and property relevance.</p></div>${icon('arrow-right')}</a><a href="/tools/"><span>${icon('calculator')}</span><div><small>Inspectable workflows</small><strong>Ten governed tools</strong><p>Inputs, assumptions, rule branches, math, citations, and outputs.</p></div>${icon('arrow-right')}</a></div></div></section>`;
+}
+
+function closing() {
+  return `<section class="closing-manifesto"><div><span class="eyebrow eyebrow--light">The standard</span><h2>Every conclusion should be usable. Every action should be accountable. Every decision should be provable.</h2></div><div><p>Hotel Wage Law v2 is designed to become the canonical operating system for hospitality wage-and-hour response—not another place to read about it.</p><a class="button button--accent button--large" href="/app/">Enter the enterprise prototype ${icon('arrow-right')}</a></div></section>`;
+}
+
+module.exports = function renderHome() {
+  return publicShell({ activeKey: 'platform', title: 'Hotel Wage Law · Hospitality intelligence and control', description: 'The hospitality wage-and-hour control plane: verified authority, portfolio applicability, accountable response, executive decisions, and operating evidence.', content: `${hero()}${thesis()}${controlPlane()}${audiences()}${evidence()}${research()}${closing()}` });
+};
diff --git a/src/pages/intelligence.js b/src/pages/intelligence.js
new file mode 100644
index 0000000..b0ed655
--- /dev/null
+++ b/src/pages/intelligence.js
@@ -0,0 +1,183 @@
+'use strict';
+
+const { publicShell } = require('../components/public-shell');
+const { icon } = require('../components/icons');
+const { product, changes, toolRecords } = require('../data/platform-data');
+
+function hero() {
+  return `<section class="intelligence-hero"><div class="intelligence-hero__inner"><div><span class="hero-kicker"><i></i> The authority graph</span><h1>Legal intelligence that knows <em>what it changes.</em></h1><p>Developments, issues, jurisdictions, and tools are connected through effective-dated sources and rules—so the platform can identify what requires review when the law moves.</p><div class="hero-actions"><a class="button button--accent button--large" href="#developments">See material developments ${icon('arrow-right')}</a><a class="button button--ghost-light button--large" href="/methodology/">Inspect the evidence standard</a></div><div class="hero-trustline"><span>${icon('source')} Primary-source passages</span><span>${icon('history')} Version history</span><span>${icon('calendar')} Effective dates</span><span>${icon('refresh')} Revalidation triggers</span></div></div>
+    <aside class="intelligence-index"><header><span class="eyebrow eyebrow--light">Current corpus</span><b>Reviewed through Jun 13, 2026</b></header><div><strong>${product.corpus.issueBriefs}</strong><span>Issue briefs</span><small>Structured legal questions</small></div><div><strong>${product.corpus.jurisdictions}</strong><span>Jurisdiction records</span><small>50 states + D.C.</small></div><div><strong>${product.corpus.hotelLaws}</strong><span>Hotel-specific laws</span><small>Local and state overlays</small></div><div><strong>${product.corpus.tools}</strong><span>Inspectable workflows</span><small>Rules, math, and outputs</small></div><footer><span>${icon('shield')} Source governed</span><span>${icon('check-circle')} Attorney reviewed</span><span>${icon('eye')} Gaps disclosed</span></footer></aside>
+  </div></section>`;
+}
+
+function indexNav() {
+  return `<nav class="public-intelligence-nav" aria-label="Intelligence sections"><div><a href="#developments"><span>${icon('signal')}</span><div><strong>Developments</strong><small>What changed</small></div></a><a href="#issues"><span>${icon('book')}</span><div><strong>Issues</strong><small>What the law requires</small></div></a><a href="/jurisdictions/"><span>${icon('map')}</span><div><strong>Jurisdictions</strong><small>Where it applies</small></div></a><a href="/tools/"><span>${icon('calculator')}</span><div><strong>Tools</strong><small>How it computes</small></div></a><a href="/methodology/"><span>${icon('shield')}</span><div><strong>Evidence</strong><small>Why it is supportable</small></div></a></div></nav>`;
+}
+
+function developments() {
+  return `<section class="developments-section" id="developments"><header class="section-lead section-lead--split"><div><span class="eyebrow">Change intelligence</span><h2>Not every update deserves the same response.</h2></div><p>Materiality is triaged against authority, effective date, issue family, jurisdiction, and likely hotel relevance. Enterprise customers can then resolve actual portfolio reach.</p></header><div class="public-signal-layout"><div class="public-signal-list">${changes.slice(0,4).map((change,index)=>`<article class="public-signal ${index===0?'public-signal--lead':''}"><time class="public-signal__date"><strong>${change.date}</strong><small>${change.jurisdiction}</small></time><div class="public-signal__body"><span>${change.id} · ${change.materiality}</span><h3>${change.title}</h3><p>${index===0?'The effective wage and benefit structure changes for covered Los Angeles hotels. Property-specific benefit and workforce facts determine the final implementation path.':'The change has been normalized to its affected rule set and hotel operating implications.'}</p><footer><span class="status status--${change.materiality==='critical'?'critical':change.materiality==='high'?'warn':'info'}">${change.status}</span><button data-open-overlay="command">Search related authority ${icon('search')}</button></footer></div><a href="/app/changes/" aria-label="Open change intelligence">${icon('arrow-right')}</a></article>`).join('')}</div>
+    <aside class="signal-method"><span class="eyebrow eyebrow--light">From signal to response</span><h3>Every published change carries a governed delta.</h3><ol><li><span>01</span><div><strong>Capture the authority</strong><p>Version, hash, publication, effective date, and passage.</p></div></li><li><span>02</span><div><strong>Normalize the rule change</strong><p>Coverage, obligation, exception, and calculation impact.</p></div></li><li><span>03</span><div><strong>Assess materiality</strong><p>Hotel relevance, urgency, downstream objects, and uncertainty.</p></div></li><li><span>04</span><div><strong>Trigger revalidation</strong><p>Identify affected content, tools, properties, findings, and decisions.</p></div></li></ol><a class="button" href="/methodology/">Read the governance standard</a></aside></div></section>`;
+}
+
+const issueFamilies = [
+  { number:'01', title:'Tips & service charges', count:'3 briefs', items:['Tip credit','Tip pooling','Service charges'], className:'' },
+  { number:'02', title:'Pay computation', count:'4 briefs', items:['Overtime & regular rate','Minimum wage','Hotel ordinances','Housekeeper pay'], className:'issue-family--teal' },
+  { number:'03', title:'Workforce structure', count:'3 briefs', items:['Exemptions','Independent contractors','Joint employer'], className:'issue-family--green' },
+  { number:'04', title:'Time & scheduling', count:'3 briefs', items:['Off-the-clock work','Meal & rest breaks','Scheduling'], className:'issue-family--gold' },
+  { number:'05', title:'Enforcement & special populations', count:'5 briefs', items:['Recordkeeping','Tip tax & payroll','PAGA & class actions','Seasonal & resorts','Minors'], className:'issue-family--violet' }
+];
+
+function issues() {
+  return `<section class="issue-library-section" id="issues"><header class="section-lead section-lead--split"><div><span class="eyebrow">Issue architecture</span><h2>Eighteen legal questions. One connected rule system.</h2></div><p>Each issue begins with a direct answer, then exposes scope, effective date, controlling authority, factual dependencies, computation, uncertainty, and operational consequence.</p></header><div class="issue-family-grid">${issueFamilies.map(family=>`<article class="issue-family ${family.className}"><header><span>${family.number}</span><b>${family.count}</b></header><h3>${family.title}</h3><ul>${family.items.map(item=>`<li>${item}</li>`).join('')}</ul><a href="#" data-toast="The ${family.title} issue family would open here.">Explore issue family ${icon('arrow-right')}</a></article>`).join('')}</div><div class="library-callout"><div><span>${icon('source')}</span><div><small>Content contract</small><h3>Direct answer → scope → reasoning → operations → authority → status</h3><p>Every substantive page follows the same supportable-answer pattern.</p></div></div><a class="button button--primary" href="/methodology/">Inspect the standard</a></div></section>`;
+}
+
+function jurisdictionPreview() {
+  return `<section class="jurisdiction-preview"><div class="jurisdiction-preview__copy"><span class="eyebrow eyebrow--light">Jurisdiction intelligence</span><h2>Fifty-one records. Thousands of local consequences.</h2><p>State-level summaries are the starting point. The platform layers local hotel wage, benefit, workload, scheduling, and retention requirements—and then resolves them against actual property facts.</p><ul class="feature-list feature-list--light"><li>${icon('check-circle')} Effective-dated wage and tip-credit rules</li><li>${icon('check-circle')} Daily and weekly overtime architecture</li><li>${icon('check-circle')} Break, scheduling, and pay-frequency overlays</li><li>${icon('check-circle')} Hotel-specific local-law inventory</li></ul><a class="button button--light" href="/jurisdictions/">Open jurisdiction intelligence ${icon('arrow-right')}</a></div><div class="jurisdiction-preview__map"><svg viewBox="0 0 800 450" role="img" aria-label="Illustrative United States portfolio map"><path class="map-country" d="M80 86 180 58l92 30 74-24 85 26 83-10 82 35 62 75-24 94-89 39-82 58-100-9-72-46-76-6-57-67-67-39-10-78Z"/><g class="map-clusters"><circle cx="165" cy="280" r="58"/><circle cx="610" cy="170" r="43"/><circle cx="135" cy="115" r="34"/><circle cx="430" cy="270" r="49"/></g><g class="map-pins"><circle cx="142" cy="285" r="11"/><circle cx="173" cy="268" r="9"/><circle cx="205" cy="293" r="8"/><circle cx="610" cy="164" r="10"/><circle cx="635" cy="188" r="8"/><circle cx="138" cy="115" r="8"/><circle cx="428" cy="271" r="8"/></g></svg><div class="map-legend"><span><i class="tier-4"></i> Tier 4 complexity</span><span><i class="tier-3"></i> Tier 3 complexity</span><span><i class="tier-2"></i> Tier 2 complexity</span><span><i class="tier-1"></i> Baseline</span></div><div class="map-proof"><span><strong>51</strong><small>State + D.C. records</small></span><span><strong>19</strong><small>Hotel-specific laws</small></span><span><strong>8</strong><small>Portfolio jurisdictions</small></span><span><strong>34</strong><small>Illustrative properties</small></span></div></div></section>`;
+}
+
+function tools() {
+  return `<section class="public-tools-section"><header class="section-lead section-lead--split"><div><span class="eyebrow">Inspectable workflows</span><h2>The output is not the product. The process is.</h2></div><p>A serious legal tool preserves scope, inputs, assumptions, rule versions, branch trace, math, citations, limitations, and downstream action.</p></header><div class="public-tool-grid">${toolRecords.slice(0,6).map((tool,index)=>`<article class="public-tool-card"><span class="public-tool-card__number">0${index+1}</span><i>${icon(tool.icon)}</i><small>${tool.label}</small><h3>${tool.title}</h3><p>${tool.description}</p><footer><span>${tool.status}</span><a href="/tools/">Open workflow ${icon('arrow-right')}</a></footer></article>`).join('')}</div><div class="public-tools-footer"><span>${icon('info')} Prototype tools are illustrative until their legal specifications, calculation fixtures, source versions, and attorney approvals are production validated.</span><a class="button button--primary" href="/tools/">Explore all ten workflows</a></div></section>`;
+}
+
+function bridge() {
+  return `<section class="public-enterprise-bridge"><div><span class="eyebrow eyebrow--light">Enterprise continuity</span><h2>Public authority is the beginning of the response—not a separate product.</h2><p>The same approved sources and rules power private property applicability, governed matters, controls, evidence, and executive decision records without exposing tenant data publicly.</p></div><a class="button button--accent button--large" href="/app/">Enter portfolio command ${icon('arrow-right')}</a></section>`;
+}
+
+module.exports = function renderIntelligence() {
+  return publicShell({ activeKey: 'intelligence', title: 'Intelligence · Hotel Wage Law', description: 'Verified hotel wage-and-hour developments, issue architecture, jurisdiction records, inspectable tools, and evidence governance.', content: `${hero()}${indexNav()}${developments()}${issues()}${jurisdictionPreview()}${tools()}${bridge()}` });
+};
diff --git a/src/pages/jurisdictions.js b/src/pages/jurisdictions.js
new file mode 100644
