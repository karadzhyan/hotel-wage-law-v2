@@ -0,0 +1,96 @@
+'use strict';
+
+const { icon, brand } = require('./icons');
+const { publicBase, publicNav } = require('../data/platform-data');
+
+function header(activeKey = 'platform') {
+  return `<header class="public-header">
+    <div class="public-header__inner">
+      <a href="/" aria-label="Hotel Wage Law home">${brand('inverse')}</a>
+      <nav class="public-nav" aria-label="Primary navigation">
+        ${publicNav.map(item => `<a href="${item.href}" ${item.key === activeKey ? 'aria-current="page"' : ''}>${item.label}</a>`).join('')}
+      </nav>
+      <div class="public-header__actions">
+        <button class="quiet-action quiet-action--inverse" data-open-overlay="command">${icon('search')} Search <kbd>/</kbd></button>
+        <a class="button button--ghost-light button--small" href="/app/">Enterprise access ${icon('arrow-right')}</a>
+      </div>
+      <button class="mobile-menu-button" data-toggle-mobile-nav aria-expanded="false" aria-label="Open navigation">${icon('menu')}</button>
+    </div>
+    <nav class="public-mobile-nav" data-mobile-nav hidden aria-label="Mobile navigation">
+      ${publicNav.map(item => `<a href="${item.href}">${item.label}</a>`).join('')}
+      <a href="/app/">Enterprise access</a>
+    </nav>
+  </header>`;
+}
+
+function footer() {
+  return `<footer class="public-footer">
+    <div class="public-footer__main">
+      <div>${brand('inverse')}<p>Independent, source-governed hospitality wage-and-hour intelligence. Built to connect legal change to accountable enterprise response.</p></div>
+      <div><h2>Intelligence</h2><a href="/intelligence/">Issue architecture</a><a href="/jurisdictions/">Jurisdictions</a><a href="/tools/">Tools</a><a href="/methodology/">Evidence standard</a></div>
+      <div><h2>Platform</h2><a href="/app/">Portfolio command</a><a href="/app/changes/">Change intelligence</a><a href="/app/research/">Grounded research</a><a href="/app/controls/">Control assurance</a></div>
+      <div class="public-footer__cta"><span class="eyebrow eyebrow--light">Enterprise</span><h2>Turn authority into accountable response.</h2><a class="button button--accent" href="/app/">Enter the control plane ${icon('arrow-right')}</a></div>
+    </div>
+    <div class="public-footer__legal"><span>© 2026 Hotel Wage Law</span><span>Educational information—not legal advice</span><span>Independent · No sponsors · No customer data in this prototype</span></div>
+  </footer>`;
+}
+
+function publicOverlays() {
+  return `<div class="command-backdrop" data-overlay="command" hidden>
+    <section class="command-palette" role="dialog" aria-modal="true" aria-labelledby="public-command-title">
+      <header><div>${icon('search')}<span><strong id="public-command-title">Search Hotel Wage Law</strong><small>Public authority only · no private enterprise context</small></span></div><button data-close-overlay aria-label="Close search">${icon('close')}</button></header>
+      <div class="command-input">${icon('search')}<input data-command-input aria-label="Search public authority" placeholder="Search issues, jurisdictions, tools, and developments…"><kbd>↵</kbd></div>
+      <div class="command-results">
+        <div data-command-default>
+          <div class="command-section"><span>Popular intelligence</span>
+            <a href="/intelligence/">${icon('book')}<span><strong>Hotel ordinances and local wage floors</strong><small>Issue briefs + jurisdiction records</small></span>${icon('arrow-right')}</a>
+            <a href="/tools/">${icon('calculator')}<span><strong>Workweek compliance auditor</strong><small>Inspectable calculation workflow</small></span>${icon('arrow-right')}</a>
+            <a href="/methodology/">${icon('shield')}<span><strong>How the evidence standard works</strong><small>Sources, rules, dates, and disclosed gaps</small></span>${icon('arrow-right')}</a>
+          </div>
+        </div>
+        <article class="command-answer" data-command-answer hidden><div class="answer-status"><span>${icon('check-circle')} Public authority search</span><span>No private context used</span></div><h2 data-answer-question></h2><p>Search results in the production system would return verified source passages, approved analysis, jurisdiction scope, effective dates, and any disclosed uncertainty.</p><div class="answer-actions"><a href="/intelligence/">Open intelligence library</a><button type="button" data-reset-command>Search again</button></div></article>
+      </div>
+      <footer><span><kbd>↑↓</kbd> Navigate</span><span><kbd>↵</kbd> Open</span><span><kbd>Esc</kbd> Close</span><span>${icon('globe')} Public context</span></footer>
+    </section>
+  </div>`;
+}
+
+function publicShell({ activeKey, title, description, content, bodyClass = 'public-page' }) {
+  return `${publicBase({ title, description, bodyClass })}
+    <a class="skip-link" href="#main-content">Skip to content</a>
+    ${header(activeKey)}
+    <main id="main-content">${content}</main>
+    ${footer()}
+    ${publicOverlays()}
+    <div class="toast-region" aria-live="polite"></div>
+  </body></html>`;
+}
+
+module.exports = { publicShell };
