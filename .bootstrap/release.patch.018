+  <symbol id="i-source" viewBox="0 0 24 24"><path d="M6 2h9l4 4v16H6z"/><path d="M14 2v5h5M9 12h7M9 16h7"/></symbol>
+  <symbol id="i-link" viewBox="0 0 24 24"><path d="m10 13 4-4M8 17l-2 2a4 4 0 0 1-6-6l4-4a4 4 0 0 1 6 0M16 7l2-2a4 4 0 0 1 6 6l-4 4a4 4 0 0 1-6 0" transform="scale(.86) translate(2 2)"/></symbol>
