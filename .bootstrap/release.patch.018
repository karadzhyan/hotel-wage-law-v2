__facts span { color: var(--ink-500); font-size: 6.5px; }
+.jurisdiction-inspector__obligations { padding: 16px 18px; }
+.jurisdiction-inspector__obligations > small { color: var(--ink-500); font-size: 6px; text-transform: uppercase; }
+.jurisdiction-inspector__obligations ul { margin: 10px 0 0; padding: 0; list-style: none; }
+.jurisdiction-inspector__obligations li { display: flex; align-items: center; gap: 7px; padding: 7px 0; border-bottom: 1px solid var(--line); font-size: 7.5px; }
+.jurisdiction-inspector__obligations svg { color: var(--green-700); }
+.jurisdiction-inspector__actions { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding: 16px 18px; background: var(--ink-50); border-top: 1px solid var(--line); }
+.jurisdiction-inspector__actions .button:first-child { grid-column: 1 / -1; }
+.compare-table { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius-md); }
+.compare-table__row { display: grid; grid-template-columns: 180px repeat(4, 1fr); min-width: 850px; }
+.compare-table__row > div { min-height: 70px; padding: 14px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); font-size: 9px; }
+.compare-table__row > div:last-child { border-right: 0; }
+.compare-table__row:last-child > div { border-bottom: 0; }
+.compare-table__row--head > div { display: grid; align-content: center; min-height: 82px; background: var(--ink-50); }
+.compare-table__row--head strong,
+.compare-table__row--head small { display: block; }
+.compare-table__row--head small { color: var(--ink-500); font-size: 6.5px; }
+.compare-table__row > div:first-child { color: var(--ink-500); background: var(--ink-50); font-size: 7px; font-weight: 760; text-transform: uppercase; }
+.compare-table__row svg { color: var(--green-700); }
+
+/* ---------- Inspectable tools ---------- */
+.tools-hero { background:
+  radial-gradient(circle at 80% 5%, rgba(7,134,138,.50), transparent 38%),
+  radial-gradient(circle at 12% 100%, rgba(36,101,216,.24), transparent 40%),
+  linear-gradient(135deg, #051222, #09273d 62%, #0a4549); }
+.tool-contract-card > header { padding: 17px 21px; color: var(--paper); background: var(--ink-900); }
+.tool-contract-card > header strong { display: block; font-size: 12px; }
+.tool-contract-card > header small { color: #91a7bc; font-size: 7px; }
+.tool-contract-card ol { margin: 0; padding: 0 21px; list-style: none; }
+.tool-contract-card li { display: grid; grid-template-columns: 31px 1fr 21px; gap: 12px; align-items: center; padding: 15px 0; border-bottom: 1px solid var(--line); }
+.tool-contract-card li > span { color: var(--teal-700); font-family: var(--font-serif); font-size: 15px; }
+.tool-contract-card strong,
+.tool-contract-card small { display: block; }
+.tool-contract-card strong { font-size: 10px; }
+.tool-contract-card small { color: var(--ink-500); font-size: 7px; }
+.tool-contract-card li > svg { color: var(--green-700); }
+.tool-contract-card footer { padding: 13px 20px; color: var(--ink-500); background: var(--ink-50); font-size: 7px; }
+.tool-filter-bar { display: flex; justify-content: space-between; gap: 20px; align-items: center; margin-bottom: 18px; padding: 10px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-md); }
+.tool-filter-bar > div { display: flex; flex-wrap: wrap; gap: 6px; }
+.tool-filter-bar button { min-height: 31px; padding: 0 11px; color: var(--ink-600); background: transparent; border: 1px solid transparent; border-radius: var(--radius-pill); font-size: 8px; }
+.tool-filter-bar button.is-active { color: var(--teal-700); background: var(--teal-50); border-color: #bfe9e3; }
+.tool-filter-bar > span { color: var(--ink-500); font-size: 8px; white-space: nowrap; }
+.tool-registry { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
+.tool-registry-card { position: relative; overflow: hidden; min-height: 300px; padding: 25px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-md); box-shadow: var(--shadow-xs); }
+.tool-registry-card::before { position: absolute; top: 0; left: 0; width: 5px; height: 100%; content: ""; background: var(--teal-500); }
+.tool-registry-card--planning::before { background: var(--blue-500); }
+.tool-registry-card--risk::before { background: var(--red-500); }
+.tool-registry-card--assessment::before { background: var(--gold-500); }
+.tool-registry-card > header { display: flex; justify-content: space-between; gap: 15px; align-items: flex-start; }
+.tool-registry-card__icon { display: grid; place-items: center; width: 43px; height: 43px; color: var(--teal-700); background: var(--teal-50); border-radius: 12px; }
+.tool-registry-card__meta { display: flex; gap: 5px; }
+.tool-registry-card__meta span { padding: 4px 7px; color: var(--ink-500); background: var(--ink-50); border: 1px solid var(--line); border-radius: var(--radius-pill); font-size: 6.5px; }
+.tool-registry-card > small { display: block; margin-top: 27px; color: var(--ink-500); font-size: 7px; font-weight: 760; text-transform: uppercase; }
+.tool-registry-card h3 { margin: 6px 0 10px; font-size: 20px; }
+.tool-registry-card > p { color: var(--ink-600); font-size: 10px; line-height: 1.6; }
+.tool-registry-card footer { position: absolute; right: 25px; bottom: 22px; left: 25px; display: flex; justify-content: space-between; gap: 15px; align-items: center; padding-top: 15px; border-top: 1px solid var(--line); }
+.tool-registry-card footer span { display: inline-flex; align-items: center; gap: 5px; color: var(--green-700); font-size: 7px; }
+.tool-registry-card footer a { display: inline-flex; align-items: center; gap: 6px; color: var(--blue-700); font-size: 8px; font-weight: 720; }
+.tool-demo-section { padding-top: 70px; }
+.tool-demo-window { display: grid; grid-template-columns: 325px minmax(0, 1fr); overflow: hidden; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }
+.tool-demo-inputs { padding: 25px; background: var(--ink-50); border-right: 1px solid var(--line); }
+.tool-demo-inputs > header { display: grid; grid-template-columns: 37px 1fr; gap: 11px; align-items: center; margin-bottom: 24px; }
+.tool-demo-inputs > header > span { display: grid; place-items: center; width: 36px; height: 36px; color: var(--teal-700); background: var(--teal-100); border-radius: 10px; }
+.tool-demo-inputs small,
+.tool-demo-inputs strong { display: block; }
+.tool-demo-inputs small { color: var(--ink-500); font-size: 6.5px; }
+.tool-demo-inputs strong { font-size: 10px; }
+.demo-field { margin-top: 15px; }
+.demo-field label { display: flex; justify-content: space-between; margin-bottom: 6px; color: var(--ink-600); font-size: 7px; }
+.demo-field input,
+.demo-field select { width: 100%; height: 37px; padding: 0 10px; background: var(--paper); border: 1px solid var(--line); border-radius: 7px; font-size: 8px; }
+.demo-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
+.tool-demo-inputs .button { width: 100%; margin-top: 22px; background: var(--teal-700); }
+.tool-demo-output { padding: 27px; }
+.tool-demo-output > header { display: flex; justify-content: space-between; gap: 15px; align-items: flex-start; }
+.tool-demo-output h2 { margin: 6px 0 0; font-size: 22px; }
+.tool-demo-output__verdict { display: grid; grid-template-columns: 1fr 105px; gap: 20px; align-items: center; margin-top: 22px; padding: 21px; color: var(--paper); background: linear-gradient(135deg, var(--ink-950), #0a5960); border-radius: var(--radius-md); }
+.tool-demo-output__verdict small,
+.tool-demo-output__verdict strong,
+.tool-demo-output__verdict p { display: block; }
+.tool-demo-output__verdict small { color: #8fb8c0; font-size: 6.5px; text-transform: uppercase; }
+.tool-demo-output__verdict strong { margin: 5px 0; font-family: var(--font-serif); font-size: 27px; font-weight: 500; }
+.tool-demo-output__verdict p { margin: 0; color: #b8d2d6; font-size: 7.5px; }
+.demo-score { position: relative; display: grid; place-items: center; width: 100px; height: 100px; border-radius: 50%; background: conic-gradient(#55d0bf 71%, rgba(255,255,255,.14) 0); }
+.demo-score::after { position: absolute; inset: 7px; content: ""; background: #0b4e58; border-radius: 50%; }
+.demo-score strong,
+.demo-score small { position: relative; z-index: 1; }
+.demo-score strong { align-self: end; color: var(--paper); font-family: var(--font-sans); font-size: 18px; font-weight: 760; }
+.demo-score small { align-self: start; color: #9dc9cf; }
+.tool-branch-trace { display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 17px; border: 1px solid var(--line); border-radius: var(--radius-sm); }
+.tool-branch-trace article { padding: 14px; border-right: 1px solid var(--line); }
+.tool-branch-trace article:last-child { border-right: 0; }
+.tool-branch-trace article > span { display: grid; place-items: center; width: 28px; height: 28px; color: var(--teal-700); background: var(--teal-50); border-radius: 8px; font-family: var(--font-serif); font-size: 11px; }
+.tool-branch-trace small,
+.tool-branch-trace strong,
+.tool-branch-trace p { display: block; }
+.tool-branch-trace small { margin-top: 12px; color: var(--ink-500); font-size: 6px; text-transform: uppercase; }
+.tool-branch-trace strong { margin: 3px 0; font-size: 8px; }
+.tool-branch-trace p { margin: 0; color: var(--ink-500); font-size: 6.5px; }
+.tool-output-contract { display: grid; grid-template-columns: 31px 1fr auto; gap: 11px; align-items: center; margin-top: 17px; padding: 14px; background: var(--gold-50); border: 1px solid #ead7a5; border-radius: var(--radius-sm); }
+.tool-output-contract > span { color: var(--gold-700); }
+.tool-output-contract strong,
+.tool-output-contract p { display: block; }
+.tool-output-contract strong { font-size: 8.5px; }
+.tool-output-contract p { margin: 2px 0 0; color: var(--ink-600); font-size: 7px; }
+.tool-output-contract button { color: var(--blue-700); background: transparent; border: 0; font-size: 7px; font-weight: 720; }
+.tools-governance-section { padding: 105px max(32px, calc((100vw - var(--public-max)) / 2)); color: var(--paper); background: linear-gradient(135deg, #061526, #0a3044); }
+.tools-governance-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
+.tools-governance-grid article { min-height: 250px; padding: 23px; background: rgba(255,255,255,.055); border: 1px solid rgba(255,255,255,.12); border-radius: var(--radius-md); }
+.tools-governance-grid article > span { display: grid; place-items: center; width: 39px; height: 39px; color: #85b7f5; background: rgba(255,255,255,.08); border-radius: 10px; }
+.tools-governance-grid small { display: block; margin-top: 34px; color: #7690a6; font-size: 7px; text-transform: uppercase; }
+.tools-governance-grid h3 { margin: 5px 0 10px; color: var(--paper); font-size: 17px; }
+.tools-governance-grid p { color: #9eafbf; font-size: 9px; line-height: 1.6; }
+
+/* ---------- Public page responsive ---------- */
+@media (max-width: 1180px) {
+  .intelligence-hero__inner,
+  .tools-hero__inner,
+  .jurisdictions-hero { grid-template-columns: 1fr; gap: 42px; }
+  .intelligence-index,
+  .tool-contract-card,
+  .jurisdiction-metrics { max-width: 720px; }
+  .public-intelligence-nav > div { grid-template-columns: repeat(3, 1fr); }
+  .public-intelligence-nav a:nth-child(3) { border-right: 0; }
+  .public-intelligence-nav a:nth-child(-n+3) { border-bottom: 1px solid var(--line); }
+  .public-signal-layout,
+  .jurisdiction-preview { grid-template-columns: 1fr; }
+  .signal-method { max-width: 760px; }
+  .issue-family-grid,
+  .public-tool-grid { grid-template-columns: repeat(2, 1fr); }
+  .jurisdiction-workspace { grid-template-columns: minmax(0, 1fr) 340px; }
+  .jurisdiction-grid { grid-template-columns: repeat(4, 1fr); }
+  .tool-demo-window { grid-template-columns: 290px minmax(0, 1fr); }
+  .tools-governance-grid { grid-template-columns: repeat(2, 1fr); }
+}
+
+@media (max-width: 820px) {
+  .intelligence-hero,
+  .tools-hero,
+  .jurisdictions-hero { padding-right: 18px; padding-left: 18px; }
+  .intelligence-hero h1,
+  .tools-hero h1,
+  .jurisdictions-hero h1 { font-size: 48px; }
+  .public-intelligence-nav > div,
+  .developments-section,
+  .issue-library-section,
+  .public-tools-section,
+  .jurisdiction-explorer,
+  .jurisdiction-compare-demo,
+  .tool-registry-section,
+  .tool-demo-section { width: calc(100% - 28px); }
+  .public-intelligence-nav > div { grid-template-columns: repeat(2, 1fr); }
+  .public-intelligence-nav a,
+  .public-intelligence-nav a:nth-child(3) { border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
+  .public-intelligence-nav a:nth-child(2n) { border-right: 0; }
+  .public-signal { grid-template-columns: 75px 1fr; }
+  .public-signal > a { grid-column: 2; justify-self: start; }
+  .issue-family-grid,
+  .public-tool-grid,
+  .tool-registry { grid-template-columns: 1fr; }
+  .issue-family { min-height: 280px; }
+  .public-enterprise-bridge,
+  .jurisdiction-bridge,
+  .tools-bridge { display: grid; padding: 75px 18px; }
+  .public-enterprise-bridge h2,
+  .jurisdiction-bridge h2,
+  .tools-bridge h2 { font-size: 38px; }
+  .jurisdiction-workspace { grid-template-columns: 1fr; }
+  .jurisdiction-grid { grid-template-columns: repeat(4, 1fr); }
+  .jurisdiction-inspector { position: static; }
+  .tier-ribbon { grid-template-columns: repeat(2, 1fr); }
+  .tier-ribbon button { border-bottom: 1px solid var(--line); }
+  .tool-filter-bar { display: grid; }
+  .tool-demo-window { grid-template-columns: 1fr; }
+  .tool-demo-inputs { border-right: 0; border-bottom: 1px solid var(--line); }
+  .tools-governance-grid { grid-template-columns: 1fr; }
+}
+
+@media (max-width: 500px) {
+  .intelligence-hero h1,
+  .tools-hero h1,
+  .jurisdictions-hero h1 { font-size: 41px; }
+  .public-intelligence-nav > div { grid-template-columns: 1fr; }
+  .public-intelligence-nav a,
+  .public-intelligence-nav a:first-child { border-right: 0; border-left: 0; }
+  .public-signal { grid-template-columns: 1fr; }
+  .public-signal > a { grid-column: 1; }
+  .library-callout,
+  .public-tools-footer { display: grid; }
+  .jurisdiction-grid { grid-template-columns: repeat(2, 1fr); }
+  .jurisdiction-metrics { grid-template-columns: 1fr; }
+  .jurisdiction-metrics > div { border-right: 0; }
+  .tier-ribbon { grid-template-columns: 1fr; }
+  .tool-branch-trace { grid-template-columns: repeat(2, 1fr); }
+  .tool-branch-trace article:nth-child(2) { border-right: 0; }
+  .tool-branch-trace article:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
+  .tool-output-contract { grid-template-columns: 31px 1fr; }
+  .tool-output-contract button { grid-column: 2; justify-self: start; }
+}
