+  <symbol id="i-check-circle" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="m8 12 2.5 2.5L16.5 8"/></symbol>
+  <symbol id="i-alert" viewBox="0 0 24 24"><path d="M12 3 2 21h20L12 3Z"/><path d="M12 9v5M12 18h.01"/></symbol>
+  <symbol id="i-clock" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></symbol>
+  <symbol id="i-calendar" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></symbol>
+  <symbol id="i-filter" viewBox="0 0 24 24"><path d="M4 5h16M7 12h10M10 19h4"/></symbol>
+  <symbol id="i-sort" viewBox="0 0 24 24"><path d="m8 4-3 3 3 3M5 7h12M16 14l3 3-3 3M19 17H7"/></symbol>
+  <symbol id="i-external" viewBox="0 0 24 24"><path d="M14 4h6v6M20 4l-9 9"/><path d="M18 13v7H4V6h7"/></symbol>
+  <symbol id="i-download" viewBox="0 0 24 24"><path d="M12 3v12m0 0 5-5m-5 5-5-5M4 21h16"/></symbol>
+  <symbol id="i-share" viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="m9 10 6-3M9 14l6 3"/></symbol>
+  <symbol id="i-more" viewBox="0 0 24 24"><circle cx="5" cy="12" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/></symbol>
+  <symbol id="i-user" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></symbol>
+  <symbol id="i-users" viewBox="0 0 24 24"><circle cx="9" cy="8" r="3"/><path d="M3 19a6 6 0 0 1 12 0M16 5a3 3 0 0 1 0 6M17 14a5 5 0 0 1 4 5"/></symbol>
+  <symbol id="i-settings" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.88l.06.06-2.83 2.83-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 0-.4 1V21H9.6v-.1A1.7 1.7 0 0 0 9 19.4a1.7 1.7 0 0 0-1.88.34l-.06.06-2.83-2.83.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.6-1A1.7 1.7 0 0 0 3 13.6H3V9.6h.1A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.34-1.88L4.2 7.06l2.83-2.83.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.6 1.7 1.7 0 0 0 .4-1V3h4v.1A1.7 1.7 0 0 0 15 4.6a1.7 1.7 0 0 0 1.88-.34l.06-.06 2.83 2.83-.06.06A1.7 1.7 0 0 0 19.4 9a1.7 1.7 0 0 0 .6 1 1.7 1.7 0 0 0 1 .4H21v4h-.1a1.7 1.7 0 0 0-1.5.6Z"/></symbol>
+  <symbol id="i-logout" viewBox="0 0 24 24"><path d="M10 5H4v14h6M14 8l4 4-4 4M8 12h10"/></symbol>
+  <symbol id="i-lock" viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></symbol>
+  <symbol id="i-briefcase" viewBox="0 0 24 24"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M9 7V4h6v3M3 12h18M10 12v2h4v-2"/></symbol>
+  <symbol id="i-calculator" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M8 5h8v4H8zM8 13h.01M12 13h.01M16 13h.01M8 17h.01M12 17h.01M16 17h.01"/></symbol>
+  <symbol id="i-clipboard" viewBox="0 0 24 24"><path d="M9 4H6v18h12V4h-3"/><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M9 11h6M9 15h6"/></symbol>
+  <symbol id="i-activity" viewBox="0 0 24 24"><path d="M3 12h4l2-7 4 14 2-7h6"/></symbol>
+  <symbol id="i-refresh" viewBox="0 0 24 24"><path d="M20 7V3l-3 3a8 8 0 1 0 2 8"/></symbol>
+  <symbol id="i-eye" viewBox="0 0 24 24"><path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></symbol>
+  <symbol id="i-flag" viewBox="0 0 24 24"><path d="M5 22V3M5 4h11l-2 4 2 4H5"/></symbol>
+  <symbol id="i-globe" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></symbol>
+  <symbol id="i-edit" viewBox="0 0 24 24"><path d="m4 20 4-1 11-11-3-3L5 16l-1 4ZM14 6l3 3"/></symbol>
+  <symbol id="i-info" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8h.01"/></symbol>
+  <symbol id="i-plus" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></symbol>
+  <symbol id="i-export" viewBox="0 0 24 24"><path d="M14 3h7v7M21 3l-9 9"/><path d="M18 13v8H3V6h8"/></symbol>
+  <symbol id="i-pin" viewBox="0 0 24 24"><path d="M12 21s7-6 7-12a7 7 0 1 0-14 0c0 6 7 12 7 12Z"/><circle cx="12" cy="9" r="2"/></symbol>
+  <symbol id="i-database" viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"/></symbol>
+  <symbol id="i-code" viewBox="0 0 24 24"><path d="m8 5-5 7 5 7M16 5l5 7-5 7M14 3 10 21"/></symbol>
+  <symbol id="i-history" viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 3-7M3 4v5h5M12 7v5l3 2"/></symbol>
+  <symbol id="i-layers" viewBox="0 0 24 24"><path d="m12 3 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5M3 16l9 5 9-5"/></symbol>
+  <symbol id="i-map" viewBox="0 0 24 24"><path d="m3 6 6-3 6 3 6-3v15l-6 3-6-3-6 3V6Z"/><path d="M9 3v15M15 6v15"/></symbol>
+  <symbol id="i-target" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1"/></symbol>
+  <symbol id="i-scale" viewBox="0 0 24 24"><path d="M12 3v18M5 6h14M7 6 3 13h8L7 6ZM17 6l-4 7h8l-4-7ZM8 21h8"/></symbol>
+  <symbol id="i-pulse" viewBox="0 0 24 24"><path d="M2 12h5l2-6 4 12 3-8 2 4h4"/></symbol>
+  <symbol id="i-spark" viewBox="0 0 24 24"><path d="m12 2 1.8 6.2L20 10l-6.2 1.8L12 18l-1.8-6.2L4 10l6.2-1.8L12 2ZM19 16l.8 2.2L22 19l-2.2.8L19 22l-.8-2.2L16 19l2.2-.8L19 16Z"/></symbol>
+  <symbol id="i-upload" viewBox="0 0 24 24"><path d="M12 16V4M7 9l5-5 5 5M4 20h16"/></symbol>
+  <symbol id="i-copy" viewBox="0 0 24 24"><rect x="8" y="8" width="12" height="12" rx="2"/><path d="M16 8V4H4v12h4"/></symbol>
+  <symbol id="i-home" viewBox="0 0 24 24"><path d="m3 11 9-8 9 8M5 10v11h14V10M9 21v-7h6v7"/></symbol>
+</svg>
diff --git a/src/assets/js/app.js b/src/assets/js/app.js
new file mode 100644
index 0000000..b0d7738
--- /dev/null
+++ b/src/assets/js/app.js
@@ -0,0 +1,395 @@
+(function () {
+  'use strict';
+
+  const body = document.body;
+  const $ = (selector, root = document) => root.querySelector(selector);
+  const $$ = (selector, root = document) => [...root.querySelectorAll(selector)];
+
+  function lockBody() {
+    body.classList.add('is-locked');
+  }
+
+  function unlockBody() {
+    if (!$('[data-overlay]:not([hidden])')) body.classList.remove('is-locked');
+  }
+
+  function showToast(message) {
+    let region = $('.toast-region');
+    if (!region) {
+      region = document.createElement('div');
+      region.className = 'toast-region';
+      region.setAttribute('aria-live', 'polite');
+      document.body.append(region);
+    }
+    const toast = document.createElement('div');
+    toast.className = 'toast';
+    toast.textContent = message;
+    region.append(toast);
+    window.setTimeout(() => toast.remove(), 3600);
+  }
+
+  function openOverlay(name) {
+    const overlay = $(`[data-overlay="${name}"]`);
+    if (!overlay) return;
+    overlay.hidden = false;
+    lockBody();
+    window.setTimeout(() => {
+      const focusable = $('input, textarea, button, a[href], [tabindex]:not([tabindex="-1"])', overlay);
+      if (focusable) focusable.focus();
+    }, 0);
+  }
+
+  function closeOverlay(overlay) {
+    if (!overlay) return;
+    overlay.hidden = true;
+    unlockBody();
+  }
+
+  $$('[data-open-overlay]').forEach(button => {
+    button.addEventListener('click', () => openOverlay(button.dataset.openOverlay));
+  });
+
+  $$('[data-close-overlay]').forEach(button => {
+    button.addEventListener('click', () => closeOverlay(button.closest('[data-overlay]')));
+  });
+
+  $$('[data-overlay]').forEach(overlay => {
+    overlay.addEventListener('mousedown', event => {
+      if (event.target === overlay) closeOverlay(overlay);
+    });
+  });
+
+  document.addEventListener('keydown', event => {
+    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
+      event.preventDefault();
+      openOverlay('command');
+    }
+    if (event.key === 'Escape') {
+      const open = $('[data-overlay]:not([hidden])');
+      if (open) closeOverlay(open);
+      closeSidebar();
+      closeMobileNav();
+    }
+  });
+
+  const commandInput = $('[data-command-input]');
+  const commandDefault = $('[data-command-default]');
+  const commandAnswer = $('[data-command-answer]');
+  if (commandInput && commandDefault && commandAnswer) {
+    commandInput.addEventListener('keydown', event => {
+      if (event.key === 'Enter' && commandInput.value.trim()) {
+        event.preventDefault();
+        commandDefault.hidden = true;
+        commandAnswer.hidden = false;
+        const question = $('[data-answer-question]');
+        if (question) question.textContent = commandInput.value.trim();
+      }
+    });
+    $('[data-reset-command]')?.addEventListener('click', () => {
+      commandInput.value = '';
+      commandDefault.hidden = false;
+      commandAnswer.hidden = true;
+      commandInput.focus();
+    });
+  }
+
+  const sidebar = $('[data-sidebar]');
+  function openSidebar() {
+    if (!sidebar) return;
+    sidebar.classList.add('is-open');
+    lockBody();
+  }
+  function closeSidebar() {
+    if (!sidebar) return;
+    sidebar.classList.remove('is-open');
+    unlockBody();
+  }
+  $('[data-open-sidebar]')?.addEventListener('click', openSidebar);
+  $('[data-close-sidebar]')?.addEventListener('click', closeSidebar);
+
+  const mobileNav = $('[data-mobile-nav]');
+  function closeMobileNav() {
+    if (!mobileNav) return;
+    mobileNav.hidden = true;
+    $('[data-toggle-mobile-nav]')?.setAttribute('aria-expanded', 'false');
+  }
+  $('[data-toggle-mobile-nav]')?.addEventListener('click', event => {
+    if (!mobileNav) return;
+    const willOpen = mobileNav.hidden;
+    mobileNav.hidden = !willOpen;
+    event.currentTarget.setAttribute('aria-expanded', String(willOpen));
+  });
+
+  const portfolioButton = $('[data-portfolio-button]');
+  const portfolioMenu = $('[data-portfolio-menu]');
+  portfolioButton?.addEventListener('click', () => {
+    const open = portfolioMenu.hidden;
+    portfolioMenu.hidden = !open;
+    portfolioButton.setAttribute('aria-expanded', String(open));
+  });
+  $$('[data-portfolio-option]').forEach(option => {
+    option.addEventListener('click', () => {
+      const label = $('[data-portfolio-label]');
+      if (label) label.textContent = option.dataset.portfolioOption;
+      portfolioMenu.hidden = true;
+      portfolioButton?.setAttribute('aria-expanded', 'false');
+      showToast(`Portfolio context changed to ${option.dataset.portfolioOption}.`);
+    });
+  });
+
+  $$('[data-toast]').forEach(element => {
+    element.addEventListener('click', event => {
+      if (element.tagName === 'A' && element.getAttribute('href') === '#') event.preventDefault();
+      showToast(element.dataset.toast);
+    });
+  });
+
+  $$('[data-signal-tab]').forEach(tab => {
+    tab.addEventListener('click', () => {
+      $$('[data-signal-tab]').forEach(item => item.classList.toggle('is-selected', item === tab));
+      const panel = $('[data-signal-detail]');
+      const data = {
+        ca: {
+          title: 'California hotel wage and benefit step',
+          source: 'City ordinance · effective July 1, 2026',
+          status: 'Material',
+          properties: '7 properties',
+          systems: '4 payroll groups',
+          decisions: '2 due'
+        },
+        ny: {
+          title: 'New York hospitality spread-of-hours rule',
+          source: 'Wage order guidance · reviewed June 9',
+          status: 'High',
+          properties: '5 properties',
+          systems: '2 payroll groups',
+          decisions: '1 due'
+        },
+        chi: {
+          title: 'Chicago tipped-wage freeze and local coverage',
+          source: 'City notice · reviewed June 8',
+          status: 'Elevated',
+          properties: '4 properties',
+          systems: '2 payroll groups',
+          decisions: '1 due'
+        },
+        dol: {
+          title: 'Federal contractor classification posture',
+          source: 'Agency action · reviewed June 7',
+          status: 'Watch',
+          properties: '18 properties',
+          systems: 'Policy review',
+          decisions: '0 due'
+        }
+      }[tab.dataset.signalTab];
+      if (!panel || !data) return;
+      $('[data-signal-title]', panel).textContent = data.title;
+      $('[data-signal-source]', panel).textContent = data.source;
+      $('[data-signal-status]', panel).textContent = data.status;
+      $('[data-signal-properties]', panel).textContent = data.properties;
+      $('[data-signal-systems]', panel).textContent = data.systems;
+      $('[data-signal-decisions]', panel).textContent = data.decisions;
+    });
+  });
+
+  $$('[data-change-item]').forEach(item => {
+    item.addEventListener('click', () => {
+      $$('[data-change-item]').forEach(candidate => candidate.classList.toggle('is-active', candidate === item));
+      const title = $('[data-change-detail-title]');
+      const meta = $('[data-change-detail-meta]');
+      if (title) title.textContent = item.dataset.title;
+      if (meta) meta.textContent = item.dataset.meta;
+    });
+  });
+
+  $$('[data-change-filter]').forEach(button => {
+    button.addEventListener('click', () => {
+      $$('[data-change-filter]').forEach(item => item.classList.toggle('is-active', item === button));
+      const filter = button.dataset.changeFilter;
+      $$('[data-change-item]').forEach(item => {
+        item.hidden = filter !== 'all' && item.dataset.materiality !== filter;
+      });
+    });
+  });
+
+  $$('[data-matter-tab]').forEach(tab => {
+    tab.addEventListener('click', () => {
+      const selected = tab.dataset.matterTab;
+      $$('[data-matter-tab]').forEach(item => {
+        item.classList.toggle('is-active', item === tab);
+        item.setAttribute('aria-selected', String(item === tab));
+      });
+      $$('[data-matter-panel]').forEach(panel => {
+        panel.hidden = panel.dataset.matterPanel !== selected;
+      });
+    });
+  });
+
+  function formatCurrency(value) {
+    return new Intl.NumberFormat('en-US', {
+      style: 'currency',
+      currency: 'USD',
+      maximumFractionDigits: 0
+    }).format(value);
+  }
+
+  function updateScenario() {
+    const properties = Number($('[data-scenario-properties]')?.value || 7);
+    const employees = Number($('[data-scenario-employees]')?.value || 842);
+    const benefit = Number($('[data-scenario-benefit]')?.value || 6.28);
+    const structure = $('[data-scenario-structure]:checked')?.value || 'mixed';
+    const structureFactor = structure === 'cash' ? 1.22 : structure === 'benefit' ? .82 : 1;
+    const base = properties * 72000 + employees * benefit * 210 * structureFactor;
+    const low = Math.round(base * .89);
+    const high = Math.round(base * 1.19);
+    $('[data-scenario-properties-output]').textContent = String(properties);
+    $('[data-scenario-employees-output]').textContent = employees.toLocaleString();
+    $('[data-scenario-benefit-output]').textContent = `$${benefit.toFixed(2)}`;
+    $('[data-scenario-range]').textContent = `${formatCurrency(low)} – ${formatCurrency(high)}`;
+    $('[data-scenario-annual]').textContent = formatCurrency(Math.round(base));
+    $('[data-scenario-readiness]').textContent = properties <= 5 ? '82%' : properties <= 7 ? '74%' : '66%';
+  }
+  $$('[data-scenario-input], [data-scenario-structure]').forEach(input => {
+    input.addEventListener('input', updateScenario);
+    input.addEventListener('change', updateScenario);
+  });
+  updateScenario();
+
+  $$('[data-control-row]').forEach(row => {
+    row.addEventListener('click', event => {
+      if (event.target.closest('a, button, input, select')) return;
+      const drawer = $('[data-control-drawer]');
+      if (!drawer) return;
+      $('[data-control-drawer-title]', drawer).textContent = row.dataset.controlTitle;
+      $('[data-control-drawer-id]', drawer).textContent = row.dataset.controlId;
+      openOverlay('control-detail');
+    });
+  });
+
+  $$('[data-research-example]').forEach(button => {
+    button.addEventListener('click', () => {
+      const input = $('[data-research-input]');
+      if (!input) return;
+      input.value = button.dataset.researchExample;
+      input.focus();
+    });
+  });
+  $('[data-run-research]')?.addEventListener('click', () => {
+    const input = $('[data-research-input]');
+    const status = $('[data-research-status]');
+    if (!input?.value.trim()) {
+      showToast('Enter a scoped legal question before running grounded research.');
+      return;
+    }
+    status.textContent = 'Grounded answer regenerated · 4 primary authorities · 1 disclosed fact gap';
+    showToast('Answer regenerated against the current source and property snapshot.');
+  });
+
+  $('[data-approve-decision]')?.addEventListener('click', event => {
+    event.currentTarget.textContent = 'Approved';
+    event.currentTarget.disabled = true;
+    const state = $('[data-decision-state]');
+    if (state) {
+      state.textContent = 'Approved for controlled implementation';
+      state.className = 'status status--good';
+    }
+    showToast('Decision approved. The provenance snapshot has been preserved.');
+  });
+
+  const jurisdictionSearch = $('[data-jurisdiction-search]');
+  jurisdictionSearch?.addEventListener('input', () => {
+    const query = jurisdictionSearch.value.toLowerCase().trim();
+    $$('[data-jurisdiction-card]').forEach(card => {
+      card.hidden = Boolean(query) && !card.dataset.jurisdictionName.toLowerCase().includes(query) && !card.dataset.jurisdictionCode.toLowerCase().includes(query);
+    });
+  });
+
+  $$('[data-jurisdiction-tier]').forEach(button => {
+    button.addEventListener('click', () => {
+      $$('[data-jurisdiction-tier]').forEach(item => item.classList.toggle('is-active', item === button));
+      const tier = button.dataset.jurisdictionTier;
+      $$('[data-jurisdiction-card]').forEach(card => {
+        card.hidden = tier !== 'all' && card.dataset.jurisdictionTier !== tier;
+      });
+    });
+  });
+
+  $$('[data-jurisdiction-card]').forEach(card => {
+    card.addEventListener('click', () => {
+      $$('[data-jurisdiction-card]').forEach(item => item.classList.toggle('is-selected', item === card));
+      const inspector = $('[data-jurisdiction-inspector]');
+      if (!inspector) return;
+      $('[data-jurisdiction-inspector-code]', inspector).textContent = card.dataset.jurisdictionCode;
+      $('[data-jurisdiction-inspector-name]', inspector).textContent = card.dataset.jurisdictionName;
+      $('[data-jurisdiction-inspector-tier]', inspector).textContent = `Tier ${card.dataset.jurisdictionTier} complexity`;
+      $('[data-jurisdiction-inspector-rate]', inspector).textContent = card.dataset.jurisdictionRate;
+      $('[data-jurisdiction-inspector-tip]', inspector).textContent = card.dataset.jurisdictionTip;
+      $('[data-jurisdiction-inspector-overtime]', inspector).textContent = card.dataset.jurisdictionOvertime;
+      $('[data-jurisdiction-inspector-hotel]', inspector).textContent = card.dataset.jurisdictionHotel;
+    });
+  });
+
+  $$('[data-tool-filter]').forEach(button => {
+    button.addEventListener('click', () => {
+      $$('[data-tool-filter]').forEach(item => item.classList.toggle('is-active', item === button));
+      const filter = button.dataset.toolFilter;
+      $$('[data-tool-card]').forEach(card => {
+        card.hidden = filter !== 'all' && card.dataset.toolFamily !== filter;
+      });
+    });
+  });
+
+  const demoRun = $('[data-run-tool-demo]');
+  demoRun?.addEventListener('click', () => {
+    const rooms = Number($('[data-demo-rooms]')?.value || 438);
+    const city = $('[data-demo-city]')?.value || 'Los Angeles';
+    const employees = Number($('[data-demo-employees]')?.value || 312);
+    const count = Math.max(3, Math.round(rooms / 110 + employees / 170));
+    $('[data-demo-obligation-count]').textContent = `${count} applicable obligations`;
+    $('[data-demo-property]').textContent = `${city} · ${rooms} rooms · ${employees} employees`;
+    showToast('Property profile recomputed. Every result retains its fact and source lineage.');
+  });
+})();
diff --git a/src/assets/manifest.webmanifest b/src/assets/manifest.webmanifest
new file mode 100644
index 0000000..273c8cb
--- /dev/null
+++ b/src/assets/manifest.webmanifest
@@ -0,0 +1,14 @@
+{
+  "name": "Hotel Wage Law",
+  "short_name": "Hotel Wage Law",
+  "description": "Hospitality wage-and-hour intelligence and control plane.",
+  "start_url": "/app/",
+  "scope": "/",
+  "display": "standalone",
+  "background_color": "#f3f5f6",
+  "theme_color": "#07182f",
+  "icons": [
+    {"src": "/assets/favicon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any maskable"}
+  ]
+}
diff --git a/src/components/app-shell.js b/src/components/app-shell.js
new file mode 100644
index 0000000..a3d6238
--- /dev/null
+++ b/src/components/app-shell.js
@@ -0,0 +1,163 @@
+'use strict';
+
+const { icon, brand } = require('./icons');
+const { appNav, appRouteMeta, appBase } = require('../data/platform-data');
+
+function navGroup(group, activeKey) {
+  return `<div class="nav-group">
+    <span>${group.label}</span>
+    ${group.items.map(item => `<a href="${item.href}" ${item.key === activeKey ? 'aria-current="page"' : ''}>
+      ${icon(item.icon)}<span>${item.label}</span>${item.count ? `<b class="nav-count">${item.count}</b>` : ''}
+    </a>`).join('')}
+  </div>`;
+}
+
+function sidebar(activeKey) {
+  return `<aside class="app-sidebar" data-sidebar>
+    <div class="app-sidebar__brand">
+      <a href="/app/" aria-label="Hotel Wage Law overview">${brand('inverse compact')}</a>
+      <button class="sidebar-close" data-close-sidebar aria-label="Close navigation">${icon('close')}</button>
+    </div>
+    <div class="portfolio-switcher">
+      <span class="portfolio-switcher__label">Active portfolio</span>
+      <button type="button" data-portfolio-button aria-expanded="false">
+        ${icon('building')}
+        <span><strong data-portfolio-label>North America portfolio</strong><small>34 properties · 8 jurisdictions</small></span>
+        ${icon('chevron-down')}
+      </button>
+      <div class="portfolio-menu" data-portfolio-menu hidden>
+        <button data-portfolio-option="North America portfolio">North America portfolio <small>34 properties</small></button>
+        <button data-portfolio-option="Southern California cluster">Southern California cluster <small>7 properties</small></button>
+        <button data-portfolio-option="Northeast portfolio">Northeast portfolio <small>8 properties</small></button>
+      </div>
+    </div>
+    <nav class="app-sidebar__nav" aria-label="Enterprise navigation">
+      ${appNav.map(group => navGroup(group, activeKey)).join('')}
+    </nav>
+    <div class="app-sidebar__footer">
+      <div class="source-health source-health--compact">
+        <span class="source-health__ring" style="--score:94"><i></i><b>94</b></span>
+        <span><strong>Source health</strong><small>1 item requires review</small></span>
+      </div>
+      <a href="/methodology/">${icon('shield')} Evidence standard</a>
+      <button type="button" data-toast="Settings are outside this prototype's persistence boundary.">${icon('settings')} Platform settings</button>
+    </div>
+  </aside>`;
+}
+
+function topbar(activeKey) {
+  const meta = appRouteMeta[activeKey] || appRouteMeta.overview;
+  return `<header class="app-topbar">
+    <button class="sidebar-open" data-open-sidebar aria-label="Open navigation">${icon('menu')}</button>
+    <nav class="breadcrumbs" aria-label="Breadcrumb">
+      <a href="/app/">North America</a>${icon('chevron-right')}<span aria-current="page">${meta.label}</span>
+    </nav>
+    <span class="topbar-status"><i></i> Authority graph current through Jun 13, 2026</span>
+    <div class="app-topbar__actions">
+      <button class="global-ask" data-open-overlay="command">${icon('spark')} <span>Ask across law + portfolio</span><kbd>⌘K</kbd></button>
+      <button class="icon-button" type="button" aria-label="Notifications" data-toast="You have 4 material notifications.">${icon('bell')}<i class="notification-dot"></i></button>
+      <button class="avatar-button" type="button" aria-label="Account menu" data-toast="Account controls are not persisted in this prototype.">AK</button>
+    </div>
+  </header>`;
+}
+
+function commandOverlay() {
+  return `<div class="command-backdrop" data-overlay="command" hidden>
+    <section class="command-palette" role="dialog" aria-modal="true" aria-labelledby="command-title">
+      <header>
+        <div>${icon('spark')}<span><strong id="command-title">Grounded ask</strong><small>Public authority + permitted portfolio context</small></span></div>
+        <button data-close-overlay aria-label="Close grounded ask">${icon('close')}</button>
+      </header>
+      <div class="command-input">${icon('search')}<input data-command-input aria-label="Ask a legal or portfolio question" placeholder="Ask a legal or portfolio question…"><kbd>↵</kbd></div>
+      <div class="command-results">
+        <div data-command-default>
+          <div class="command-section"><span>Continue working</span>
+            <a href="/app/matters/la-hotel-wage-2026/">${icon('matter')}<span><strong>Los Angeles hotel wage step</strong><small>MTR-2026-041 · 7 properties · decision due</small></span>${icon('arrow-right')}</a>
+            <a href="/app/controls/">${icon('shield')}<span><strong>Benefit credit variance control</strong><small>CTL-PAY-014 · 2 open exceptions</small></span>${icon('arrow-right')}</a>
+          </div>
+          <div class="command-section"><span>Try asking</span>
+            <button type="button" data-command-suggestion="Which properties are affected by the July 1 Los Angeles hotel wage step?">${icon('building')}<span><strong>Which properties are affected by the July 1 wage step?</strong><small>Uses current property and rule snapshots</small></span></button>
+            <button type="button" data-command-suggestion="Why is the benefit credit blocked at Downtown LA Hotel 01?">${icon('source')}<span><strong>Why is the benefit credit blocked at DTLA-01?</strong><small>Returns the fact gap and source chain</small></span></button>
+          </div>
+        </div>
+        <article class="command-answer" data-command-answer hidden>
+          <div class="answer-status"><span>${icon('check-circle')} Grounded in 6 governed records</span><span>As of Jun 13, 2026</span></div>
+          <h2 data-answer-question></h2>
+          <p>Seven Southern California properties require review. Three are confirmed above the ordinance threshold, two require benefit-credit substantiation, and two are not covered based on current location and room-count facts.</p>
+          <div class="answer-actions"><a href="/app/changes/">Open impact analysis</a><button type="button" data-open-overlay="sources">Inspect source chain</button><button type="button" data-reset-command>Ask another question</button></div>
+        </article>
+      </div>
+      <footer><span><kbd>↑↓</kbd> Navigate</span><span><kbd>↵</kbd> Open</span><span><kbd>Esc</kbd> Close</span><span>${icon('lock')} Permission scoped</span></footer>
+    </section>
+  </div>`;
+}
+
+function sourceOverlay() {
+  return `<div class="drawer-backdrop" data-overlay="sources" hidden>
+    <aside class="source-drawer" role="dialog" aria-modal="true" aria-labelledby="source-title">
+      <header><div><span class="eyebrow">Evidence chain</span><h2 id="source-title">Why this conclusion is supportable</h2></div><button data-close-overlay aria-label="Close source chain">${icon('close')}</button></header>
+      <div class="source-drawer__summary">${icon('shield')}<div><strong>Current and internally consistent</strong><p>Three primary authorities, one approved interpretation, and two verified property facts support this conclusion.</p></div></div>
+      <ol class="evidence-chain">
+        <li><span>1</span><div><small>Primary authority · verified</small><strong>Los Angeles Municipal Code § 187.02</strong><p>Effective July 1, 2026 · passage retained · reviewed Jun 13</p><button data-toast="The source viewer is represented by this evidence drawer in the prototype.">Open cited passage</button></div>${icon('external')}</li>
+        <li><span>2</span><div><small>Official guidance · verified</small><strong>Office of Wage Standards implementation guidance</strong><p>Health-benefit treatment and covered-hotel threshold.</p><button data-toast="Guidance passage opened in the evidence workflow.">Open cited passage</button></div>${icon('external')}</li>
+        <li><span>3</span><div><small>Rule version · approved</small><strong>LA hotel wage and health-benefit rule v3</strong><p>Deterministic coverage predicates + counsel-reviewed ambiguity note.</p><button data-toast="Rule specification opened.">Inspect rule trace</button></div>${icon('code')}</li>
+        <li><span>4</span><div><small>Enterprise fact · verified</small><strong>DTLA-01 room count and locality</strong><p>438 rooms · City of Los Angeles · source: property master.</p><button data-toast="Property fact provenance opened.">Inspect fact provenance</button></div>${icon('database')}</li>
+        <li><span>5</span><div><small>Enterprise fact · open</small><strong>Qualifying health-benefit contribution</strong><p>Carrier statement for June remains outstanding.</p><button data-toast="Evidence request opened.">Open evidence request</button></div>${icon('alert')}</li>
+      </ol>
+      <div class="disclosed-gap">${icon('alert')}<div><strong>One fact gap remains</strong><p>The wage floor is confirmed. The amount of any lawful health-benefit credit remains conditional pending June carrier evidence.</p></div></div>
+      <footer><a class="button button--secondary" href="/methodology/">Evidence standard</a><button class="button button--primary" data-toast="Source bundle prepared for export.">${icon('download')} Export source bundle</button></footer>
+    </aside>
+  </div>`;
+}
+
+function appShell({ activeKey, content, rail = '' }) {
+  const meta = appRouteMeta[activeKey] || appRouteMeta.overview;
+  return `${appBase({ title: meta.title, description: meta.description, bodyClass: 'app-page' })}
+    <a class="skip-link" href="#main-content">Skip to content</a>
+    <div class="app-shell">
+      ${sidebar(activeKey)}
+      <div class="app-main">
+        ${topbar(activeKey)}
+        <main class="app-content" id="main-content">
+          <div class="page-layout ${rail ? 'page-layout--with-rail' : ''}">
+            <div class="page-primary">${content}</div>
+            ${rail ? `<aside class="page-rail">${rail}</aside>` : ''}
+          </div>
+        </main>
+      </div>
+    </div>
+    ${commandOverlay()}
+    ${sourceOverlay()}
+    <div class="toast-region" aria-live="polite"></div>
+  </body></html>`;
+}
+
+module.exports = { appShell };
diff --git a/src/components/icons.js b/src/components/icons.js
new file mode 100644
index 0000000..31d1f99
--- /dev/null
+++ b/src/components/icons.js
@@ -0,0 +1,22 @@
+'use strict';
+
+function icon(name, className = '') {
+  return `<svg class="icon ${className}" aria-hidden="true"><use href="/assets/icons.svg#i-${name}"></use></svg>`;
+}
+
+function brand(variant = '') {
+  const inverse = variant.includes('inverse') ? ' brand--inverse' : '';
+  const compact = variant.includes('compact') ? ' brand--compact' : '';
+  return `<span class="brand${inverse}${compact}">
+    <span class="brand-mark" aria-hidden="true"><span></span><span></span><span></span></span>
+    <span class="brand-copy"><strong>Hotel Wage Law</strong><small>Hospitality intelligence & control</small></span>
+  </span>`;
+}
+
+module.exports = { icon, brand };
diff --git a/src/components/public-shell.js b/src/components/public-shell.js
